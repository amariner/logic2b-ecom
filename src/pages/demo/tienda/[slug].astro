---
import Shop from '../../../layouts/Shop.astro';
import { shopConfig } from '../../../../shop.config';
import { getProductBySlug } from '../../../lib/db';
import { formatEurCents } from '../../../lib/format';
import { notFoundResponse } from '../../../lib/not-found';

export const prerender = false;

const { slug = '' } = Astro.params;
const product = await getProductBySlug(Astro.locals.runtime.env.DB, slug);
// Producto borrado o desactivado: servimos la 404 propia con su estado real.
const notFound = product ? null : await notFoundResponse(Astro.locals.runtime.env, Astro.url);
if (!product || notFound) {
  return notFound;
}

const categoryLabel = shopConfig.categories.find((cat) => cat.id === product.category)?.label ?? product.category;

// Schema Product+Offer válido: parte del argumento de venta (aunque la demo sea noindex).
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: product.name,
  description: product.description,
  image: new URL(product.image, Astro.site).href,
  sku: product.slug,
  category: categoryLabel,
  offers: {
    '@type': 'Offer',
    priceCurrency: 'EUR',
    price: (product.price_cents / 100).toFixed(2),
    availability: product.stock > 0 ? 'https://schema.org/InStock' : 'https://schema.org/OutOfStock',
    url: new URL(`/demo/tienda/${product.slug}`, Astro.site).href,
  },
};
---

<Shop title={product.name} description={product.description}>
  <main class="mx-auto max-w-6xl px-4 py-10">
    <nav class="text-sm text-stone-500">
      <a href="/demo/tienda" class="hover:text-ink hover:underline">Tienda</a>
      <span aria-hidden="true"> / </span>
      <a href={`/demo/tienda?categoria=${product.category}`} class="hover:text-ink hover:underline">{categoryLabel}</a>
    </nav>

    <div class="mt-6 grid gap-8 md:grid-cols-2 md:gap-14">
      <div class="overflow-hidden rounded-3xl bg-cream">
        <img
          src={product.image}
          alt={product.name}
          width="800"
          height="800"
          class="aspect-square w-full object-cover"
        />
      </div>

      <div class="md:py-4">
        <p class="text-sm font-medium uppercase tracking-wide text-brand">{categoryLabel}</p>
        <h1 class="mt-2 font-display text-3xl sm:text-4xl">{product.name}</h1>
        <p class="mt-4 text-2xl font-semibold">{formatEurCents(product.price_cents)}</p>
        <p class="mt-5 leading-relaxed text-stone-600">{product.description}</p>

        {product.stock > 0 ? (
          <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:items-center">
            <div class="flex items-center gap-3">
              <label class="text-sm text-stone-600" for="qty">Cantidad</label>
              <input
                id="qty"
                type="number"
                min="1"
                max={Math.min(product.stock, 99)}
                value="1"
                class="w-20 rounded-btn border border-stone-300 px-4 py-2.5 text-center"
              />
            </div>
            <button
              type="button"
              data-add-to-cart={product.slug}
              class="flex-1 rounded-btn bg-brand px-8 py-3 font-semibold text-white shadow-lg shadow-brand/20 transition hover:bg-brand-dark active:scale-[.98] sm:flex-none"
            >Añadir al carrito</button>
          </div>
        ) : (
          <p class="mt-8 inline-block rounded-btn bg-red-50 px-4 py-2 font-medium text-red-600">Agotado temporalmente</p>
        )}

        <dl class="mt-10 space-y-2 border-t border-stone-200 pt-5 text-sm text-stone-600">
          <div class="flex gap-2"><dt class="font-medium text-ink">Envío:</dt> <dd>{shopConfig.legal.shippingNote}</dd></div>
          <div class="flex gap-2"><dt class="font-medium text-ink">Devoluciones:</dt> <dd>{shopConfig.legal.returnsNote}</dd></div>
          {product.stock > 0 && product.stock <= 10 && (
            <div class="flex gap-2"><dt class="font-medium text-ink">Stock:</dt> <dd>quedan {product.stock} unidades</dd></div>
          )}
        </dl>
      </div>
    </div>
  </main>

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />

  <script>
    import { addToCart } from '../../../lib/cart-client';

    const btn = document.querySelector<HTMLButtonElement>('[data-add-to-cart]');
    const qtyInput = document.querySelector<HTMLInputElement>('#qty');
    btn?.addEventListener('click', () => {
      const qty = Math.max(1, Number(qtyInput?.value ?? 1) || 1);
      addToCart(btn.dataset.addToCart ?? '', qty);
      const prev = btn.textContent;
      btn.textContent = 'Añadido ✓';
      setTimeout(() => (btn.textContent = prev), 900);
    });
  </script>
</Shop>
