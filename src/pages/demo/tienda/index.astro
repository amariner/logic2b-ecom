---
import Shop from '../../../layouts/Shop.astro';
import { shopConfig } from '../../../../shop.config';
import { getActiveProducts, isSortOption } from '../../../lib/db';
import { formatEurCents } from '../../../lib/format';

export const prerender = false;

const url = Astro.url;
const rawCategory = url.searchParams.get('categoria') ?? '';
const category = shopConfig.categories.some((cat) => cat.id === rawCategory) ? rawCategory : undefined;
const rawSort = url.searchParams.get('orden') ?? 'featured';
const sort = isSortOption(rawSort) ? rawSort : 'featured';

const products = await getActiveProducts(Astro.locals.runtime.env.DB, { category, sort });

const sortOptions = [
  { id: 'featured', label: 'Destacados' },
  { id: 'price-asc', label: 'Precio: menor a mayor' },
  { id: 'price-desc', label: 'Precio: mayor a menor' },
  { id: 'name', label: 'Nombre A-Z' },
];

const linkFor = (cat?: string, ord?: string): string => {
  const params = new URLSearchParams();
  if (cat) params.set('categoria', cat);
  if (ord && ord !== 'featured') params.set('orden', ord);
  const qs = params.toString();
  return `/demo/tienda${qs ? `?${qs}` : ''}`;
};
---

<Shop title="Tienda" description="Catálogo demo de La Botiga del Maestrat">
  <main class="mx-auto max-w-6xl px-4 py-10">
    <h1 class="font-display text-3xl sm:text-4xl">Productes de la terra</h1>
    <p class="mt-2 max-w-2xl text-stone-600">Aceites, embutidos, mieles, vinos, conservas y quesos del Maestrat.</p>

    <div class="mt-8 flex flex-wrap items-center justify-between gap-4">
      <nav class="-mx-4 flex gap-2 overflow-x-auto px-4 pb-1 sm:mx-0 sm:flex-wrap sm:overflow-visible sm:px-0" aria-label="Categorías">
        <a
          href={linkFor(undefined, sort)}
          class:list={['shrink-0 rounded-full px-4 py-2 text-sm font-medium transition', !category ? 'bg-ink text-white' : 'bg-cream text-stone-700 hover:bg-stone-200']}
        >Todo</a>
        {shopConfig.categories.map((cat) => (
          <a
            href={linkFor(cat.id, sort)}
            class:list={['shrink-0 rounded-full px-4 py-2 text-sm font-medium transition', category === cat.id ? 'bg-ink text-white' : 'bg-cream text-stone-700 hover:bg-stone-200']}
          >{cat.label}</a>
        ))}
      </nav>

      <form method="get" class="text-sm">
        {category && <input type="hidden" name="categoria" value={category} />}
        <label class="text-stone-500" for="orden">Ordenar:</label>
        <select id="orden" name="orden" class="ml-1 rounded-full border border-stone-200 bg-white px-3 py-1.5" onchange="this.form.submit()">
          {sortOptions.map((opt) => (
            <option value={opt.id} selected={opt.id === sort}>{opt.label}</option>
          ))}
        </select>
      </form>
    </div>

    <ul class="mt-8 grid grid-cols-2 gap-x-4 gap-y-8 sm:grid-cols-3 sm:gap-x-6 lg:grid-cols-4">
      {products.map((prod) => (
        <li class="group flex flex-col">
          <a href={`/demo/tienda/${prod.slug}`} class="flex flex-1 flex-col">
            <div class="overflow-hidden rounded-2xl bg-cream">
              <img
                src={prod.image}
                alt={prod.name}
                width="800"
                height="800"
                loading="lazy"
                class="aspect-square w-full object-cover transition duration-300 group-hover:scale-[1.04]"
              />
            </div>
            <div class="flex flex-1 flex-col gap-0.5 pt-3">
              <h2 class="text-sm font-medium leading-snug text-ink">{prod.name}</h2>
              <p class="mt-auto pt-1 text-base font-semibold">{formatEurCents(prod.price_cents)}</p>
              {prod.stock === 0 && <p class="text-xs font-medium text-red-600">Agotado</p>}
            </div>
          </a>
          <div class="pt-2.5">
            <button
              type="button"
              data-add-to-cart={prod.slug}
              disabled={prod.stock === 0}
              class="w-full rounded-full border border-ink/15 bg-white px-3 py-2 text-sm font-semibold text-ink transition hover:border-ink hover:bg-ink hover:text-white disabled:cursor-not-allowed disabled:border-stone-200 disabled:bg-stone-100 disabled:text-stone-400"
            >Añadir al carrito</button>
          </div>
        </li>
      ))}
    </ul>

    {products.length === 0 && <p class="mt-12 text-center text-stone-500">No hay productos en esta categoría.</p>}
  </main>

  <script>
    import { addToCart } from '../../../lib/cart-client';

    document.querySelectorAll<HTMLButtonElement>('[data-add-to-cart]').forEach((btn) => {
      btn.addEventListener('click', () => {
        addToCart(btn.dataset.addToCart ?? '');
        const prev = btn.textContent;
        btn.textContent = 'Añadido ✓';
        setTimeout(() => (btn.textContent = prev), 900);
      });
    });
  </script>
</Shop>
