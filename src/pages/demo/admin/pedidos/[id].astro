---
import Admin from '../../../../layouts/Admin.astro';
import { formatEurCents } from '../../../../lib/format';

export const prerender = false;

const id = Number(Astro.params.id);
const db = Astro.locals.runtime.env.DB;

type OrderRow = {
  id: number; order_number: string; email: string; customer_name: string; address_json: string;
  subtotal_cents: number; shipping_cents: number; total_cents: number; status: string;
  tracking_carrier: string | null; tracking_number: string | null; created_at: string;
};
const order = Number.isInteger(id)
  ? await db.prepare('SELECT * FROM orders WHERE id = ?').bind(id).first<OrderRow>()
  : null;
if (!order) return new Response(null, { status: 404 });

const { results: items } = await db
  .prepare('SELECT name_snapshot, unit_price_cents, qty FROM order_items WHERE order_id = ?')
  .bind(id)
  .all<{ name_snapshot: string; unit_price_cents: number; qty: number }>();

const { results: events } = await db
  .prepare('SELECT from_status, to_status, note, created_at FROM order_events WHERE order_id = ? ORDER BY id')
  .bind(id)
  .all<{ from_status: string | null; to_status: string; note: string | null; created_at: string }>();

const addr = JSON.parse(order.address_json) as {
  name: string; phone: string | null; street: string; city: string; postal_code: string; zone: string;
  // Opcionales de facturación (pueden faltar en pedidos antiguos)
  nif?: string | null; company?: string | null;
};

const statusLabel: Record<string, string> = {
  pending: 'Pendiente de pago', paid: 'Pagado', shipped: 'Enviado', delivered: 'Entregado', cancelled: 'Cancelado',
};
---

<Admin title={`Pedido ${order.order_number}`} active="pedidos">
  <a href="/demo/admin" class="text-sm text-stone-600 hover:text-stone-900">← Todos los pedidos</a>
  <div class="mt-2 flex items-center justify-between">
    <h1 class="text-2xl font-bold">
      <span class="font-mono">{order.order_number}</span>
      <span class="ml-2 align-middle rounded-full bg-stone-200 px-2.5 py-0.5 text-xs font-medium text-stone-700">{statusLabel[order.status] ?? order.status}</span>
    </h1>
    <p class="text-sm text-stone-600">{order.created_at.slice(0, 16)}</p>
  </div>

  <div class="mt-6 grid gap-6 lg:grid-cols-3">
    <section class="lg:col-span-2 space-y-6">
      <div class="rounded-lg border border-stone-300 bg-white p-4">
        <h2 class="font-semibold">Líneas del pedido</h2>
        <table class="mt-3 w-full text-sm">
          <tbody class="divide-y divide-stone-100">
            {items.map((item) => (
              <tr>
                <td class="py-2">{item.name_snapshot}</td>
                <td class="py-2 text-right text-stone-500">{item.qty} × {formatEurCents(item.unit_price_cents)}</td>
                <td class="py-2 text-right font-medium">{formatEurCents(item.qty * item.unit_price_cents)}</td>
              </tr>
            ))}
            <tr><td class="pt-3 text-stone-500">Envío</td><td></td><td class="pt-3 text-right">{formatEurCents(order.shipping_cents)}</td></tr>
            <tr><td class="py-1 font-bold">Total</td><td></td><td class="py-1 text-right font-bold">{formatEurCents(order.total_cents)}</td></tr>
          </tbody>
        </table>
      </div>

      <div class="rounded-lg border border-stone-300 bg-white p-4">
        <h2 class="font-semibold">Historial</h2>
        <ol class="mt-3 space-y-2 text-sm">
          {events.map((event) => (
            <li class="flex gap-3">
              <span class="w-32 shrink-0 text-stone-500">{event.created_at.slice(0, 16)}</span>
              <span>
                <strong>{statusLabel[event.to_status] ?? event.to_status}</strong>
                {event.note && <span class="text-stone-500"> — {event.note}</span>}
              </span>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <aside class="space-y-6">
      <div class="rounded-lg border border-stone-300 bg-white p-4 text-sm">
        <h2 class="font-semibold">Envío a</h2>
        <p class="mt-2">{addr.name}</p>
        <p>{addr.street}</p>
        <p>{addr.postal_code} {addr.city}</p>
        <p class="text-stone-500">{order.email}{addr.phone ? ` · ${addr.phone}` : ''}</p>
        {(addr.nif || addr.company) && (
          <p class="mt-2 rounded bg-amber-50 p-2 text-amber-900">
            Factura: {[addr.company, addr.nif].filter(Boolean).join(' · ')}
          </p>
        )}
        {order.tracking_number && (
          <p class="mt-2 rounded bg-sky-50 p-2 text-sky-900">
            {order.tracking_carrier}: <strong>{order.tracking_number}</strong>
          </p>
        )}
      </div>

      {order.status === 'paid' && (
        <form data-ship-form data-order-id={order.id} class="rounded-lg border border-stone-300 bg-white p-4 text-sm">
          <h2 class="font-semibold">Marcar como enviado</h2>
          <label class="mt-3 block text-xs font-medium text-stone-600" for="carrier">Transportista</label>
          <input id="carrier" name="carrier" required list="carriers" class="mt-1 w-full rounded border border-stone-300 px-2 py-1.5" />
          <datalist id="carriers">
            <option value="SEUR"></option><option value="Correos Express"></option>
            <option value="GLS"></option><option value="MRW"></option><option value="CTT"></option>
          </datalist>
          <label class="mt-2 block text-xs font-medium text-stone-600" for="tracking">Nº de seguimiento</label>
          <input id="tracking" name="tracking" required class="mt-1 w-full rounded border border-stone-300 px-2 py-1.5" />
          <p data-ship-error class="mt-2 hidden text-red-700"></p>
          <button type="submit" class="mt-3 w-full rounded bg-stone-900 px-3 py-2 font-medium text-white hover:bg-stone-700">
            Marcar enviado y avisar al cliente
          </button>
        </form>
      )}

      {order.status === 'paid' && (
        <div class="rounded-lg border border-stone-300 bg-white p-4 text-sm">
          <h2 class="font-semibold">Cancelar pedido</h2>
          <p class="mt-1 text-stone-500">Solo si ya has reembolsado el pago en Stripe. Devuelve el stock de las líneas al catálogo.</p>
          <p data-cancel-error class="mt-2 hidden text-red-700"></p>
          <button
            type="button"
            data-cancel
            data-order-id={order.id}
            class="mt-3 w-full rounded border border-red-300 bg-white px-3 py-2 font-medium text-red-700 hover:bg-red-50"
          >Cancelar y devolver stock</button>
        </div>
      )}

      {order.status === 'shipped' && (
        <button
          type="button"
          data-deliver
          data-order-id={order.id}
          class="w-full rounded border border-stone-400 bg-white px-3 py-2 text-sm font-medium hover:bg-stone-50"
        >Marcar como entregado</button>
      )}
    </aside>
  </div>

  <script>
    const shipForm = document.querySelector<HTMLFormElement>('[data-ship-form]');
    shipForm?.addEventListener('submit', (ev) => {
      ev.preventDefault();
      if (!shipForm.reportValidity()) return;
      const data = new FormData(shipForm);
      void (async () => {
        const res = await fetch(`/api/admin/orders/${shipForm.dataset.orderId}`, {
          method: 'PATCH',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({
            status: 'shipped',
            tracking_carrier: String(data.get('carrier') ?? ''),
            tracking_number: String(data.get('tracking') ?? ''),
          }),
        });
        if (res.ok) {
          window.location.reload();
        } else {
          const body = (await res.json()) as { error?: string };
          const errEl = document.querySelector<HTMLElement>('[data-ship-error]')!;
          errEl.textContent = body.error ?? 'Error inesperado';
          errEl.classList.remove('hidden');
        }
      })();
    });

    document.querySelector<HTMLButtonElement>('[data-deliver]')?.addEventListener('click', (ev) => {
      const btn = ev.currentTarget as HTMLButtonElement;
      void fetch(`/api/admin/orders/${btn.dataset.orderId}`, {
        method: 'PATCH',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify({ status: 'delivered' }),
      }).then(() => window.location.reload());
    });

    document.querySelector<HTMLButtonElement>('[data-cancel]')?.addEventListener('click', (ev) => {
      const btn = ev.currentTarget as HTMLButtonElement;
      if (!window.confirm('¿Cancelar este pedido y devolver el stock? Solo hazlo si ya has reembolsado el pago en Stripe.')) return;
      void (async () => {
        const res = await fetch(`/api/admin/orders/${btn.dataset.orderId}`, {
          method: 'PATCH',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({ status: 'cancelled' }),
        });
        if (res.ok) {
          window.location.reload();
        } else {
          const body = (await res.json()) as { error?: string };
          const errEl = document.querySelector<HTMLElement>('[data-cancel-error]')!;
          errEl.textContent = body.error ?? 'Error inesperado';
          errEl.classList.remove('hidden');
        }
      })();
    });
  </script>
</Admin>
