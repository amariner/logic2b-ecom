---
import Admin from '../../../layouts/Admin.astro';

export const prerender = false;

type Row = { id: number; to_addr: string; subject: string; body_html: string; created_at: string };
const db = Astro.locals.runtime.env.DB;
// El cierre del recorrido comercial solo existe en la demo pública: en la
// tienda de un cliente (DEMO_MODE off) este panel es SUYO y no lleva venta.
const demoMode = Astro.locals.runtime.env.DEMO_MODE === 'true';
const EMAIL_LIMIT = 100;
const { results: emails } = await db
  .prepare('SELECT id, to_addr, subject, body_html, created_at FROM emails_outbox ORDER BY id DESC LIMIT ?')
  .bind(EMAIL_LIMIT)
  .all<Row>();
const total = (await db.prepare('SELECT COUNT(*) AS n FROM emails_outbox').first<{ n: number }>())?.n ?? 0;
---

<Admin title="Emails" active="emails">
  <h1 class="text-2xl font-bold">Bandeja de salida simulada</h1>
  <p class="mt-1 text-sm text-stone-600">
    Estos son los emails que el sistema <strong>habría enviado</strong> (confirmaciones de pedido, avisos de envío).
    En la demo se capturan aquí; en producción salen por Resend con el dominio del comercio.
  </p>

  {total > EMAIL_LIMIT && (
    <p class="mt-3 rounded border border-amber-200 bg-amber-50 p-3 text-sm text-amber-900">
      Mostrando los {EMAIL_LIMIT} más recientes de {total}. Los más antiguos siguen en la copia de seguridad del panel.
    </p>
  )}

  <div class="mt-4 space-y-3">
    {emails.map((email) => (
      <details class="rounded-lg border border-stone-300 bg-white">
        <summary class="flex cursor-pointer flex-wrap items-center gap-x-4 gap-y-1 px-4 py-3 text-sm">
          <span class="text-stone-500">{email.created_at.slice(0, 16)}</span>
          <span class="font-medium">{email.subject}</span>
          <span class="text-stone-500">→ {email.to_addr}</span>
        </summary>
        <iframe
          srcdoc={email.body_html}
          title={email.subject}
          sandbox=""
          class="h-96 w-full border-t border-stone-200 bg-white"
        ></iframe>
      </details>
    ))}
  </div>

  {emails.length === 0 && (
    <p class="mt-8 rounded-lg border border-stone-300 bg-white p-8 text-center text-stone-500">
      Aún no hay emails. Completa una compra en la <a href="/demo/tienda" class="underline">tienda demo</a> y verás aquí la confirmación.
    </p>
  )}

  {/* Fin del recorrido guiado (funnel F11.6). Sobrio a propósito: es el
      registro del panel. Quien llega aquí ha visto el sistema entero. */}
  {demoMode && (
    <div class="mt-10 rounded-lg border border-stone-300 bg-white p-6">
      <p class="font-semibold">Fin del recorrido: esto es todo lo que hay que aprender.</p>
      <p class="mt-1 text-sm text-stone-600">
        Has visto la compra, el pedido gestionado en el panel y los emails que salen
        solos. Tu tienda funcionaría exactamente así, con tu marca y tus productos.
      </p>
      <p class="mt-3 text-sm font-medium">
        <a href="https://wa.me/34626434316?text=Hola%2C%20acabo%20de%20probar%20la%20demo%20de%20LogicEcom." class="underline underline-offset-2 hover:text-stone-600">WhatsApp 626 434 316</a>
        <span class="font-normal text-stone-400"> · </span>
        <a href="mailto:hola@logic2b.com?subject=Mi%20tienda%20online%20con%20LogicEcom" class="underline underline-offset-2 hover:text-stone-600">hola@logic2b.com</a>
        <span class="font-normal text-stone-400"> · </span>
        <a href="/#precios" class="underline underline-offset-2 hover:text-stone-600">Ver precios</a>
      </p>
    </div>
  )}
</Admin>
