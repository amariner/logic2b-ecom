---
import Admin from '../../../layouts/Admin.astro';
import { formatEurCents } from '../../../lib/format';
import { ORDER_STATUSES } from '../../../lib/order-transitions';

export const prerender = false;

const rawStatus = Astro.url.searchParams.get('estado') ?? '';
const status = (ORDER_STATUSES as readonly string[]).includes(rawStatus) ? rawStatus : undefined;

type Row = {
  id: number;
  order_number: string;
  customer_name: string;
  email: string;
  total_cents: number;
  status: string;
  created_at: string;
};

const db = Astro.locals.runtime.env.DB;
const query = status
  ? db.prepare('SELECT id, order_number, customer_name, email, total_cents, status, created_at FROM orders WHERE status = ? ORDER BY created_at DESC LIMIT 200').bind(status)
  : db.prepare('SELECT id, order_number, customer_name, email, total_cents, status, created_at FROM orders ORDER BY created_at DESC LIMIT 200');
const { results: orders } = await query.all<Row>();

const counts = (
  await db.prepare('SELECT status, count(*) AS n FROM orders GROUP BY status').all<{ status: string; n: number }>()
).results;
const countFor = (st: string): number => counts.find((c) => c.status === st)?.n ?? 0;

const statusLabel: Record<string, string> = {
  pending: 'Pendiente de pago',
  paid: 'Pagado',
  shipped: 'Enviado',
  delivered: 'Entregado',
  cancelled: 'Cancelado',
};
const statusBadge: Record<string, string> = {
  pending: 'bg-stone-200 text-stone-700',
  paid: 'bg-amber-100 text-amber-900',
  shipped: 'bg-sky-100 text-sky-900',
  delivered: 'bg-green-100 text-green-900',
  cancelled: 'bg-red-100 text-red-800',
};
---

<Admin title="Pedidos" active="pedidos">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-bold">Pedidos</h1>
    <a
      href="/api/admin/orders/export.csv"
      class="rounded border border-stone-400 bg-white px-4 py-1.5 text-sm font-medium hover:bg-stone-50"
      download
    >Exportar CSV para Packlink/SendCloud</a>
  </div>

  <nav class="mt-4 flex flex-wrap gap-2 text-sm" aria-label="Filtro por estado">
    <a href="/demo/admin" class:list={['rounded-full border px-3 py-1', !status ? 'border-stone-900 bg-stone-900 text-white' : 'border-stone-300 bg-white hover:border-stone-500']}>
      Todos ({counts.reduce((sum, c) => sum + c.n, 0)})
    </a>
    {ORDER_STATUSES.map((st) => (
      <a href={`/demo/admin?estado=${st}`} class:list={['rounded-full border px-3 py-1', status === st ? 'border-stone-900 bg-stone-900 text-white' : 'border-stone-300 bg-white hover:border-stone-500']}>
        {statusLabel[st]} ({countFor(st)})
      </a>
    ))}
  </nav>

  <div class="mt-4 overflow-x-auto rounded-lg border border-stone-300 bg-white">
    <table class="w-full text-sm">
      <thead class="border-b border-stone-200 bg-stone-50 text-left text-xs uppercase tracking-wide text-stone-500">
        <tr>
          <th class="px-4 py-2">Nº pedido</th>
          <th class="px-4 py-2">Fecha</th>
          <th class="px-4 py-2">Cliente</th>
          <th class="px-4 py-2 text-right">Total</th>
          <th class="px-4 py-2">Estado</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-stone-100">
        {orders.map((order) => (
          <tr class="hover:bg-stone-50">
            <td class="px-4 py-2 font-mono">
              <a href={`/demo/admin/pedidos/${order.id}`} class="text-sky-700 underline-offset-2 hover:underline">{order.order_number}</a>
            </td>
            <td class="px-4 py-2 text-stone-500">{order.created_at.slice(0, 16)}</td>
            <td class="px-4 py-2">{order.customer_name} <span class="text-stone-400">· {order.email}</span></td>
            <td class="px-4 py-2 text-right font-medium">{formatEurCents(order.total_cents)}</td>
            <td class="px-4 py-2">
              <span class:list={['rounded-full px-2 py-0.5 text-xs font-medium', statusBadge[order.status]]}>
                {statusLabel[order.status] ?? order.status}
              </span>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
    {orders.length === 0 && (
      <p class="p-8 text-center text-stone-500">
        No hay pedidos{status ? ' en este estado' : ''} todavía. Haz una compra en la <a href="/demo/tienda" class="underline">tienda demo</a>.
      </p>
    )}
  </div>
</Admin>
