---
import Admin from '../../../layouts/Admin.astro';
import { shopConfig } from '../../../../shop.config';

export const prerender = false;

type Row = { id: number; zone: string; label: string; price_cents: number; free_over_cents: number | null; active: number };
const { results: rates } = await Astro.locals.runtime.env.DB.prepare(
  'SELECT * FROM shipping_rates ORDER BY price_cents',
).all<Row>();

const zoneLabel = new Map(shopConfig.shipping.zones.map((zone) => [zone.id, zone.label]));
---

<Admin title="Envíos" active="envios">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-bold">Tarifas de envío</h1>
    <a href="/api/admin/orders/export.csv" download
      class="rounded border border-stone-400 bg-white px-4 py-1.5 text-sm font-medium hover:bg-stone-50">
      Exportar CSV para Packlink/SendCloud
    </a>
  </div>
  <p class="mt-1 text-sm text-stone-600">
    Tarifa plana por zona. «Gratis desde» en euros; vacío = nunca gratis. Se aplica al momento en la tienda.
  </p>

  <div class="mt-4 overflow-x-auto rounded-lg border border-stone-300 bg-white">
    <table class="w-full text-sm">
      <thead class="border-b border-stone-200 bg-stone-50 text-left text-xs uppercase tracking-wide text-stone-500">
        <tr>
          <th class="px-4 py-2">Zona</th>
          <th class="px-4 py-2">Servicio</th>
          <th class="px-4 py-2 text-right">Precio €</th>
          <th class="px-4 py-2 text-right">Gratis desde €</th>
          <th class="px-4 py-2 text-center">Activa</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-stone-100">
        {rates.map((rate) => (
          <tr class:list={[rate.active === 0 && 'opacity-50']}>
            <td class="px-4 py-2 font-medium">{zoneLabel.get(rate.zone) ?? rate.zone}</td>
            <td class="px-4 py-2 text-stone-500">{rate.label}</td>
            <td class="px-4 py-2 text-right">
              <input data-field="price" data-id={rate.id} aria-label={`Precio de la zona ${zoneLabel.get(rate.zone) ?? rate.zone}`} value={(rate.price_cents / 100).toFixed(2)} inputmode="decimal"
                class="w-20 rounded border border-transparent px-1 py-0.5 text-right hover:border-stone-300 focus:border-stone-400" />
            </td>
            <td class="px-4 py-2 text-right">
              <input data-field="free_over" data-id={rate.id} aria-label={`Envío gratis desde, zona ${zoneLabel.get(rate.zone) ?? rate.zone}`} value={rate.free_over_cents === null ? '' : (rate.free_over_cents / 100).toFixed(2)} inputmode="decimal" placeholder="—"
                class="w-20 rounded border border-transparent px-1 py-0.5 text-right hover:border-stone-300 focus:border-stone-400" />
            </td>
            <td class="px-4 py-2 text-center">
              <input data-field="active" data-id={rate.id} type="checkbox" aria-label={`Activa: zona ${zoneLabel.get(rate.zone) ?? rate.zone}`} checked={rate.active === 1} class="h-4 w-4 accent-stone-900" />
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
  <p data-save-status class="mt-2 h-5 text-sm text-stone-600"></p>

  <div class="mt-8 rounded-lg border border-stone-300 bg-white p-4 text-sm text-stone-600">
    <h2 class="font-semibold text-stone-900">Cómo funciona el flujo de envíos</h2>
    <ol class="mt-2 list-decimal space-y-1 pl-5">
      <li>Cuando llega un pedido pagado, aparece en <a href="/demo/admin?estado=paid" class="underline">Pedidos → Pagados</a>.</li>
      <li>Exporta el CSV y súbelo a Packlink PRO o SendCloud para imprimir las etiquetas.</li>
      <li>En el detalle del pedido, pulsa «Marcar enviado» y pega el nº de seguimiento: el cliente recibe el aviso automáticamente.</li>
    </ol>
  </div>

  <script>
    const statusEl = document.querySelector<HTMLElement>('[data-save-status]')!;

    // Revertir al último valor guardado con éxito si el servidor rechaza el
    // cambio: dejar el valor rechazado en el input haría creer que se guardó.
    async function save(id: string, patch: Record<string, unknown>, input: HTMLInputElement): Promise<void> {
      statusEl.textContent = 'Guardando…';
      const res = await fetch(`/api/admin/shipping-rates/${id}`, {
        method: 'PATCH',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify(patch),
      });
      if (res.ok) {
        statusEl.textContent = 'Guardado ✓';
        if (input.type === 'checkbox') input.defaultChecked = input.checked;
        else input.defaultValue = input.value;
        setTimeout(() => (statusEl.textContent = ''), 1500);
      } else {
        statusEl.textContent = 'Error al guardar';
        if (input.type === 'checkbox') input.checked = input.defaultChecked;
        else input.value = input.defaultValue;
      }
    }

    document.querySelectorAll<HTMLInputElement>('[data-field]').forEach((input) => {
      const id = input.dataset.id ?? '';
      input.addEventListener('change', () => {
        const field = input.dataset.field;
        if (field === 'price') {
          // Vacío ≠ 0 €: un campo de precio en blanco es un valor inválido, no un
          // envío gratis silencioso (Number('') === 0 lo coló antes de este arreglo).
          const raw = input.value.trim();
          const cents = raw === '' ? NaN : Math.round(Number(raw.replace(',', '.')) * 100);
          if (Number.isInteger(cents) && cents >= 0) void save(id, { price_cents: cents }, input);
          else {
            statusEl.textContent = 'Precio inválido';
            input.value = input.defaultValue;
          }
        }
        if (field === 'free_over') {
          const raw = input.value.trim();
          if (raw === '') {
            void save(id, { free_over_cents: null }, input);
          } else {
            const cents = Math.round(Number(raw.replace(',', '.')) * 100);
            if (Number.isInteger(cents) && cents >= 0) void save(id, { free_over_cents: cents }, input);
            else {
              statusEl.textContent = 'Importe inválido';
              input.value = input.defaultValue;
            }
          }
        }
        if (field === 'active') void save(id, { active: input.checked }, input);
      });
    });
  </script>
</Admin>
