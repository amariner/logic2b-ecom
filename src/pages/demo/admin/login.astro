---
/**
 * Login del panel. En demo la contraseña se muestra en la propia página:
 * el objetivo es enseñar el flujo real de acceso, no esconder la demo.
 * En producción el panel va además tras Cloudflare Access (ver docs/PRODUCCION.md).
 */
import Base from '../../../layouts/Base.astro';
import { shopConfig } from '../../../../shop.config';
import {
  ADMIN_COOKIE_NAME,
  DEMO_ADMIN_PASSWORD,
  SESSION_TTL_MS,
  createSessionToken,
  resolveCookieSecret,
} from '../../../lib/admin-auth';

export const prerender = false;

const env = Astro.locals.runtime.env;
const demoMode = env.DEMO_MODE === 'true';
const secret = resolveCookieSecret(env);

const rawNext = Astro.url.searchParams.get('next') ?? '';
const nextPath =
  rawNext.startsWith('/demo/admin') && !rawNext.startsWith('/demo/admin/login') ? rawNext : '/demo/admin';

const loggedOut = Astro.url.searchParams.has('salir');
if (loggedOut) {
  Astro.cookies.delete(ADMIN_COOKIE_NAME, { path: '/' });
}

let error: string | null = null;
if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const password = String(form.get('password') ?? '');
  if (demoMode && secret && password === DEMO_ADMIN_PASSWORD) {
    Astro.cookies.set(ADMIN_COOKIE_NAME, await createSessionToken(secret), {
      path: '/',
      httpOnly: true,
      sameSite: 'lax',
      secure: Astro.url.protocol === 'https:',
      maxAge: SESSION_TTL_MS / 1000,
    });
    return Astro.redirect(nextPath, 303);
  }
  error = demoMode
    ? `Contraseña incorrecta. En esta demo es «${DEMO_ADMIN_PASSWORD}».`
    : 'Login demo deshabilitado: en producción el acceso al panel va tras Cloudflare Access.';
}
---

<Base title={`Acceso al panel · ${shopConfig.name}`} noindex>
  <div class="flex min-h-screen flex-col bg-stone-100">
    <div class="border-b border-sky-200 bg-sky-50 px-4 py-1.5 text-center text-xs text-sky-900">
      Panel de demostración. En producción está protegido además con Cloudflare Access (login del comercio).
    </div>

    <main class="mx-auto flex w-full max-w-md flex-1 flex-col justify-center px-4 py-10">
      <div class="rounded-lg border border-stone-300 bg-white p-6 sm:p-8">
        <p class="font-bold">{shopConfig.name} <span class="font-normal text-stone-500">· panel</span></p>
        <h1 class="mt-4 text-2xl font-bold">Acceso al panel</h1>

        {demoMode && (
          <p class="mt-3 rounded border border-green-200 bg-green-50 p-3 text-sm text-green-900">
            Esto es una demo: la contraseña es <strong class="font-mono">{DEMO_ADMIN_PASSWORD}</strong>.
            El login existe para enseñar el flujo real del comercio.
          </p>
        )}

        {loggedOut && !error && (
          <p class="mt-3 rounded border border-stone-200 bg-stone-50 p-3 text-sm text-stone-700">Sesión cerrada.</p>
        )}

        {error && <p class="mt-3 rounded border border-red-200 bg-red-50 p-3 text-sm text-red-800">{error}</p>}

        <form method="post" action={`/demo/admin/login?next=${encodeURIComponent(nextPath)}`} class="mt-5">
          <label class="block text-sm font-medium text-stone-700" for="password">Contraseña</label>
          <input
            id="password"
            name="password"
            type="password"
            required
            autocomplete="current-password"
            autofocus
            class="mt-1.5 w-full rounded border border-stone-300 px-3 py-2 focus:border-stone-900 focus:outline-none"
          />
          <button
            type="submit"
            class="mt-4 w-full rounded bg-stone-900 px-4 py-2.5 font-medium text-white hover:bg-black"
          >Entrar</button>
        </form>
      </div>

      <p class="mt-4 text-center text-sm text-stone-600">
        <a href="/demo/tienda" class="hover:text-stone-900 hover:underline">← Volver a la tienda demo</a>
      </p>
    </main>
  </div>
</Base>
