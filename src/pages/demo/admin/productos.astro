---
import Admin from '../../../layouts/Admin.astro';
import { allCategoryLabels } from '../../../lib/collections';

export const prerender = false;

type Row = { id: number; slug: string; name: string; price_cents: number; stock: number; category: string; active: number };
const { results: products } = await Astro.locals.runtime.env.DB.prepare(
  'SELECT id, slug, name, price_cents, stock, category, active FROM products ORDER BY category, name',
).all<Row>();

// El backoffice es UNO y ve los productos de todas las tiendas: las etiquetas
// salen de la unión de categorías del registro de colecciones.
const categoryLabel = allCategoryLabels();
---

<Admin title="Productos" active="productos">
  <h1 class="text-2xl font-bold">Productos</h1>
  <p class="mt-1 text-sm text-stone-600">
    Edita precio (en euros), stock o desactiva un producto. Los cambios se guardan al salir de la celda.
    Los pedidos ya realizados nunca cambian: guardan su propio precio.
  </p>

  <div class="mt-4 overflow-x-auto rounded-lg border border-stone-300 bg-white">
    <table class="w-full text-sm">
      <thead class="border-b border-stone-200 bg-stone-50 text-left text-xs uppercase tracking-wide text-stone-500">
        <tr>
          <th class="px-4 py-2">Producto</th>
          <th class="px-4 py-2">Categoría</th>
          <th class="px-4 py-2 text-right">Precio €</th>
          <th class="px-4 py-2 text-right">Stock</th>
          <th class="px-4 py-2 text-center">Activo</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-stone-100">
        {products.map((prod) => (
          <tr class:list={['hover:bg-stone-50', prod.active === 0 && 'opacity-50']}>
            <td class="px-4 py-1.5">
              <input data-field="name" data-id={prod.id} value={prod.name} aria-label={`Nombre de ${prod.slug}`} class="w-full min-w-56 rounded border border-transparent px-1 py-0.5 hover:border-stone-300 focus:border-stone-400" />
            </td>
            <td class="px-4 py-1.5 text-stone-500">{categoryLabel.get(prod.category) ?? prod.category}</td>
            <td class="px-4 py-1.5 text-right">
              <input data-field="price" data-id={prod.id} aria-label={`Precio de ${prod.name}`} value={(prod.price_cents / 100).toFixed(2)} inputmode="decimal" class="w-20 rounded border border-transparent px-1 py-0.5 text-right hover:border-stone-300 focus:border-stone-400" />
            </td>
            <td class="px-4 py-1.5 text-right">
              <input data-field="stock" data-id={prod.id} aria-label={`Stock de ${prod.name}`} value={prod.stock} inputmode="numeric" class="w-16 rounded border border-transparent px-1 py-0.5 text-right hover:border-stone-300 focus:border-stone-400" />
            </td>
            <td class="px-4 py-1.5 text-center">
              <input data-field="active" data-id={prod.id} type="checkbox" aria-label={`Activo: ${prod.name}`} checked={prod.active === 1} class="h-4 w-4 accent-stone-900" />
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
  <p data-save-status class="mt-2 h-5 text-sm text-stone-600"></p>

  <script>
    const statusEl = document.querySelector<HTMLElement>('[data-save-status]')!;

    // Si el servidor rechaza el valor, revertimos al último guardado con éxito
    // (no al de la carga de página, que puede ser una edición previa de la misma
    // sesión) — dejar el valor rechazado en el input engañaría al comercio
    // haciéndole creer que se guardó.
    async function save(id: string, patch: Record<string, unknown>, input: HTMLInputElement): Promise<void> {
      statusEl.textContent = 'Guardando…';
      const res = await fetch(`/api/admin/products/${id}`, {
        method: 'PATCH',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify(patch),
      });
      if (res.ok) {
        statusEl.textContent = 'Guardado ✓';
        if (input.type === 'checkbox') input.defaultChecked = input.checked;
        else input.defaultValue = input.value;
        setTimeout(() => (statusEl.textContent = ''), 1500);
      } else {
        const body = (await res.json()) as { error?: string };
        statusEl.textContent = `Error: ${body.error ?? 'inesperado'}`;
        if (input.type === 'checkbox') input.checked = input.defaultChecked;
        else input.value = input.defaultValue;
      }
    }

    document.querySelectorAll<HTMLInputElement>('[data-field]').forEach((input) => {
      const id = input.dataset.id ?? '';
      const field = input.dataset.field ?? '';
      input.addEventListener('change', () => {
        if (field === 'name') {
          const name = input.value.trim();
          if (name.length < 2) {
            statusEl.textContent = 'El nombre debe tener al menos 2 caracteres';
            input.value = input.defaultValue;
            return;
          }
          void save(id, { name }, input);
        }
        if (field === 'price') {
          const raw = input.value.trim();
          const cents = raw === '' ? NaN : Math.round(Number(raw.replace(',', '.')) * 100);
          if (Number.isInteger(cents) && cents >= 0) void save(id, { price_cents: cents }, input);
          else {
            statusEl.textContent = 'Precio inválido';
            input.value = input.defaultValue;
          }
        }
        if (field === 'stock') {
          const raw = input.value.trim();
          const stock = raw === '' ? NaN : Number(raw);
          if (Number.isInteger(stock) && stock >= 0) void save(id, { stock }, input);
          else {
            statusEl.textContent = 'Stock inválido';
            input.value = input.defaultValue;
          }
        }
        if (field === 'active') void save(id, { active: input.checked }, input);
      });
    });
  </script>
</Admin>
