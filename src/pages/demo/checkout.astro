---
import Shop from '../../layouts/Shop.astro';
---

<Shop title="Checkout" description="Datos de envío y pago">
  <main class="mx-auto max-w-xl px-4 py-8">
    <h1 class="font-display text-3xl sm:text-4xl">Datos de envío</h1>
    <p class="mt-1 text-sm text-muted-foreground">
      Demo: el pago está <strong>simulado</strong>, no se cobra nada. En una tienda real, aquí se
      redirige al pago seguro de Stripe y la tarjeta nunca toca nuestro servidor.
    </p>

    <!-- Resumen del pedido: siempre precios recalculados en servidor -->
    <div data-summary class="mt-6 hidden rounded-2xl bg-muted p-5 sm:p-6">
      <h2 class="text-sm font-semibold uppercase tracking-wide text-muted-foreground">Tu pedido</h2>
      <ul data-summary-lines class="mt-3 divide-y divide-border text-sm"></ul>
      <dl class="mt-3 space-y-1.5 border-t border-border pt-3 text-sm">
        <div class="flex justify-between"><dt class="text-muted-foreground">Subtotal</dt><dd data-summary-subtotal class="font-medium"></dd></div>
        <div class="flex justify-between"><dt class="text-muted-foreground">Envío <span data-summary-shipping-label class="text-muted-foreground"></span></dt><dd data-summary-shipping></dd></div>
        <div class="flex justify-between border-t border-border pt-2 text-base font-bold"><dt>Total</dt><dd data-summary-total></dd></div>
      </dl>
    </div>

    <form data-checkout-form class="mt-6 space-y-4" novalidate>
      <div>
        <label class="block text-sm font-medium" for="name">Nombre y apellidos</label>
        <input id="name" name="name" required minlength="2" autocomplete="name"
          class="mt-1 w-full rounded-xl border border-border px-4 py-2.5 focus:border-brand focus:outline-none" />
      </div>
      <div>
        <label class="block text-sm font-medium" for="email">Email</label>
        <input id="email" name="email" type="email" required autocomplete="email"
          class="mt-1 w-full rounded-xl border border-border px-4 py-2.5 focus:border-brand focus:outline-none" />
        <p class="mt-1 text-xs text-muted-foreground">Aquí llegarán la confirmación y el seguimiento (en la demo, a la bandeja simulada).</p>
      </div>
      <div>
        <label class="block text-sm font-medium" for="street">Dirección</label>
        <input id="street" name="street" required minlength="3" autocomplete="street-address"
          class="mt-1 w-full rounded-xl border border-border px-4 py-2.5 focus:border-brand focus:outline-none" />
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium" for="postal_code">Código postal</label>
          <input id="postal_code" name="postal_code" required pattern="\\d{5}" inputmode="numeric" maxlength="5" autocomplete="postal-code"
            class="mt-1 w-full rounded-xl border border-border px-4 py-2.5 focus:border-brand focus:outline-none" />
        </div>
        <div>
          <label class="block text-sm font-medium" for="city">Población</label>
          <input id="city" name="city" required minlength="2" autocomplete="address-level2"
            class="mt-1 w-full rounded-xl border border-border px-4 py-2.5 focus:border-brand focus:outline-none" />
        </div>
      </div>
      <div>
        <label class="block text-sm font-medium" for="phone">Teléfono <span class="font-normal text-muted-foreground">(opcional)</span></label>
        <input id="phone" name="phone" type="tel" autocomplete="tel"
          class="mt-1 w-full rounded-xl border border-border px-4 py-2.5 focus:border-brand focus:outline-none" />
      </div>

      <details class="rounded-xl border border-border bg-muted/60 px-4 py-3">
        <summary class="cursor-pointer text-sm font-medium text-muted-foreground">¿Necesitas factura? <span class="font-normal text-muted-foreground">(opcional)</span></summary>
        <div class="mt-3 grid gap-4 sm:grid-cols-2">
          <div>
            <label class="block text-sm font-medium" for="nif">NIF / CIF</label>
            <input id="nif" name="nif" maxlength="20" autocomplete="off" placeholder="B12345678"
              class="mt-1 w-full rounded-xl border border-border bg-card px-4 py-2.5 focus:border-brand focus:outline-none" />
          </div>
          <div>
            <label class="block text-sm font-medium" for="company">Razón social</label>
            <input id="company" name="company" maxlength="160" autocomplete="organization"
              class="mt-1 w-full rounded-xl border border-border bg-card px-4 py-2.5 focus:border-brand focus:outline-none" />
          </div>
        </div>
        <p class="mt-2 text-xs text-muted-foreground">El comercio los tendrá junto al pedido para emitir tu factura.</p>
      </details>

      <p data-checkout-error class="hidden rounded border border-red-200 bg-red-50 p-3 text-sm text-destructive"></p>

      <button type="submit" data-checkout-submit
        class="w-full rounded-btn bg-brand px-8 py-3.5 font-semibold text-white shadow-lg shadow-brand/20 transition hover:bg-brand-dark active:scale-[.98] disabled:bg-muted disabled:shadow-none">
        Confirmar pedido (pago simulado)
      </button>
      <p class="text-center text-xs text-muted-foreground">
        Demo: el pago se simula automáticamente, no hace falta tarjeta ni datos bancarios.
      </p>
    </form>
  </main>

  <script>
    import { readCart } from '../../lib/cart-client';
    import { formatEurCents as eur } from '../../lib/format';

    const form = document.querySelector<HTMLFormElement>('[data-checkout-form]')!;
    const errorEl = document.querySelector<HTMLElement>('[data-checkout-error]')!;
    const submitBtn = document.querySelector<HTMLButtonElement>('[data-checkout-submit]')!;

    const cpStored = localStorage.getItem('ecom-demo-cp');
    const cpInput = document.querySelector('#postal_code') as HTMLInputElement;
    if (cpStored) cpInput.value = cpStored;

    if (readCart().length === 0) {
      window.location.replace('/demo/carrito');
    }

    // Resumen del pedido, siempre recalculado en servidor (mismo /api/cart/quote del carrito).
    type SummaryQuote = {
      lines: { name: string; qty: number; line_total_cents: number; status: string }[];
      subtotal_cents: number;
      shipping_cents: number | null;
      total_cents: number | null;
      shipping: { label: string } | null;
    };

    async function refreshSummary(): Promise<void> {
      const lines = readCart();
      if (lines.length === 0) return;
      const postal = cpInput.value.trim();
      const res = await fetch('/api/cart/quote', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify({ lines, ...(postal.length === 5 ? { postal_code: postal } : {}) }),
      });
      if (!res.ok) return;
      const quote = (await res.json()) as SummaryQuote;

      const list = document.querySelector('[data-summary-lines]')!;
      list.innerHTML = '';
      for (const line of quote.lines) {
        if (line.status !== 'ok') continue;
        const li = document.createElement('li');
        li.className = 'flex justify-between gap-3 py-1.5';
        const nameEl = document.createElement('span');
        nameEl.textContent = `${line.qty} × ${line.name}`;
        const totalEl = document.createElement('span');
        totalEl.className = 'shrink-0 font-medium';
        totalEl.textContent = eur(line.line_total_cents);
        li.appendChild(nameEl);
        li.appendChild(totalEl);
        list.appendChild(li);
      }
      document.querySelector('[data-summary-subtotal]')!.textContent = eur(quote.subtotal_cents);
      document.querySelector('[data-summary-shipping]')!.textContent =
        quote.shipping_cents === null ? 'según CP' : quote.shipping_cents === 0 ? 'Gratis' : eur(quote.shipping_cents);
      document.querySelector('[data-summary-shipping-label]')!.textContent = quote.shipping
        ? `(${quote.shipping.label})`
        : '';
      document.querySelector('[data-summary-total]')!.textContent =
        quote.total_cents === null ? '—' : eur(quote.total_cents);
      document.querySelector('[data-summary]')!.classList.remove('hidden');
    }

    cpInput.addEventListener('input', () => {
      if (cpInput.value.trim().length === 5) void refreshSummary();
    });
    void refreshSummary();

    form.addEventListener('submit', (ev) => {
      ev.preventDefault();
      if (!form.reportValidity()) return;
      errorEl.classList.add('hidden');
      submitBtn.disabled = true;
      submitBtn.textContent = 'Confirmando el pedido…';

      const data = new FormData(form);
      const phone = String(data.get('phone') ?? '').trim();
      const nif = String(data.get('nif') ?? '').trim();
      const company = String(data.get('company') ?? '').trim();
      const payload = {
        lines: readCart(),
        customer: {
          name: String(data.get('name') ?? '').trim(),
          email: String(data.get('email') ?? '').trim(),
          street: String(data.get('street') ?? '').trim(),
          city: String(data.get('city') ?? '').trim(),
          postal_code: String(data.get('postal_code') ?? '').trim(),
          ...(phone ? { phone } : {}),
          ...(nif ? { nif } : {}),
          ...(company ? { company } : {}),
        },
      };

      void (async () => {
        try {
          const res = await fetch('/api/checkout/session', {
            method: 'POST',
            headers: { 'content-type': 'application/json' },
            body: JSON.stringify(payload),
          });
          const body = (await res.json()) as { url?: string; error?: string };
          if (!res.ok || !body.url) {
            throw new Error(body.error ?? 'No se pudo procesar el pedido');
          }
          window.location.assign(body.url);
        } catch (err) {
          errorEl.textContent = err instanceof Error ? err.message : 'Error inesperado';
          errorEl.classList.remove('hidden');
          submitBtn.disabled = false;
          submitBtn.textContent = 'Confirmar pedido (pago simulado)';
        }
      })();
    });
  </script>
</Shop>
