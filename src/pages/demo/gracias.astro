---
import ThanksPage from '../../components/store/ThanksPage.astro';
import { defaultCollection } from '../../lib/collections';
import { getOrderBySessionId } from '../../lib/thanks';

export const prerender = false;

const order = await getOrderBySessionId(
  Astro.locals.runtime.env.DB,
  Astro.url.searchParams.get('session_id'),
);
---

<ThanksPage collection={defaultCollection()} order={order} />
