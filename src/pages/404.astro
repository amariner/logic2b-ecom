---
// Página 404 propia (sustituye a la genérica del Worker). Cero JS.
import Base from '../layouts/Base.astro';
---

<Base title="Página no encontrada — Logic2B Commerce Kit" noindex={true}>
  <div class="flex min-h-screen flex-col bg-paper text-ink">
    <header class="border-b border-black/5">
      <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-5">
        <a href="/" class="font-display text-lg">Logic2B<span class="text-brand">.</span></a>
        <a
          href="/demo/tienda"
          class="rounded-full bg-ink px-4 py-2 text-sm font-semibold text-white transition hover:bg-black sm:px-5"
        >Ver la demo</a>
      </div>
    </header>

    <main class="mx-auto flex w-full max-w-2xl flex-1 flex-col items-center justify-center px-5 py-20 text-center">
      <p class="font-display text-7xl text-brand sm:text-8xl">404</p>
      <h1 class="mt-4 font-display text-2xl sm:text-3xl">Esta página no existe</h1>
      <p class="mt-3 max-w-md leading-relaxed text-stone-600">
        Puede que el enlace esté mal escrito o que la página haya cambiado de sitio.
        Estas rutas sí llevan a alguna parte:
      </p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:gap-4">
        <a href="/" class="rounded-full bg-brand px-7 py-3 font-semibold text-white transition hover:bg-brand-dark">Ir a la página principal</a>
        <a href="/demo/tienda" class="rounded-full border border-stone-300 px-7 py-3 font-semibold text-ink transition hover:border-ink">Entrar en la tienda demo</a>
      </div>
      <p class="mt-6 text-sm text-stone-500">
        ¿Buscabas el panel? <a href="/demo/admin" class="text-brand underline hover:text-brand-dark">Está aquí</a>.
      </p>
    </main>
  </div>
</Base>
