<style is:global>
  /* ── Motion de la landing (F11.3 sesión 2) — CSS primero, JS después ────
     Todo lo de aquí degrada a página completa y estática: sin soporte de
     scroll-driven animations o con prefers-reduced-motion, no se anima nada
     y el contenido real ya está en el DOM. */

  /* Acento mutante: el script fija --accent-text* con la tienda activa de la
     galería; el texto acentuado usa la variante AA-safe precalculada en build.
     Sin JS (o antes de interactuar) cae al acento por defecto. Fuera de
     @layer para ganar a las utilidades (patrón del tema Guide en global.css). */
  [data-landing] .text-brand {
    color: var(--accent-text, var(--color-brand));
  }
  [data-landing] :is(.text-brand-dark, .hover\:text-brand-dark:hover) {
    color: var(--accent-text-dark, var(--color-brand-dark));
  }
  /* Dark-ready: sobre fondo oscuro la cadena AA se invierte (un acento tinta,
     como el de Forma Interior, sería invisible). Hoy el sitio pinta en claro;
     esto protege la página el día que el modo oscuro se active. */
  .dark [data-landing] :is(.text-brand, .text-brand-dark, .hover\:text-brand-dark:hover) {
    color: var(--accent-text-dm, var(--color-brand));
  }
  /* El cambio de acento se funde: color, no movimiento. */
  [data-landing] :is(.text-brand, .text-brand-dark, .bg-brand, .border-brand) {
    transition-property: color, background-color, border-color;
    transition-duration: 0.3s;
  }

  /* Cifras count-up en CSS puro: un <integer> registrado interpola y
     counter() lo pinta. El texto real (.stat-static) es el fallback y lo que
     leen los lectores de pantalla. */
  @property --stat-n {
    syntax: "<integer>";
    inherits: false;
    initial-value: 0;
  }
  @keyframes stat-count {
    from { --stat-n: 0; }
    to { --stat-n: var(--stat, 0); }
  }
  /* Solo transform: nada de opacity en tarjetas (axe audita el estado inicial
     y el texto perdería contraste) y nada de font-weight/opacity en el H1 —
     animar el peso de la variable re-shapea el texto en main thread y costó
     2,1 s de TBT en Lighthouse (medido); el H1 es además el LCP. */
  @keyframes rise-in {
    from { transform: translateY(1.25rem); }
  }
  @keyframes hero-title-in {
    from { transform: translateY(0.5rem); }
  }
  @keyframes hero-fade-in {
    from { opacity: 0.02; transform: translateY(0.4rem); }
  }
  .stat-count { display: none; }

  /* Solo pantalla: en impresión todo queda estático y completo. */
  @media screen and (prefers-reduced-motion: no-preference) {
    /* Entrada del hero: una vez, al cargar. El peso variable de Inter se asienta
       de 320 a 600 — tipografía display animada sin cargar nada nuevo. */
    .hero-title { animation: hero-title-in 0.7s cubic-bezier(0.2, 0.7, 0.2, 1) both; }
    .hero-fade { animation: hero-fade-in 0.7s cubic-bezier(0.2, 0.7, 0.2, 1) both; animation-delay: var(--d, 0s); }

    @supports (animation-timeline: view()) {
      .stat-static {
        position: absolute;
        width: 1px;
        height: 1px;
        overflow: hidden;
        clip-path: inset(50%);
      }
      .stat { position: relative; }
      .stat-count {
        display: inline-block;
        counter-reset: stat-n var(--stat-n);
        animation: stat-count linear both;
        animation-timeline: view();
        animation-range: entry 20% cover 45%;
      }
      .stat-count::before { content: attr(data-prefix); }
      .stat-count::after { content: counter(stat-n) attr(data-suffix); }

      /* Entrada suave de tarjetas conducida por el scroll (scrubbed). */
      .rise {
        animation: rise-in linear both;
        animation-timeline: view();
        animation-range: entry 5% entry 45%;
      }
    }
  }
</style>

<script>
  // Script único de la landing (decisión D1: vanilla, sin dependencias, ≤15 KB;
  // este pesa ~2 KB). Tres piezas, todas mejora progresiva: el acento que muta
  // con la tienda activa, el autoplay del vídeo de Iris y la calculadora.
  const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;

  // 1 · El acento de la landing muta al de la tienda activa de la galería.
  //     «Activa» = la tarjeta más cercana al centro de la tira. Los valores
  //     (acento real, par de texto AA-safe, texto sobre acento) vienen
  //     precalculados del servidor en data-attrs; aquí solo se copian a
  //     variables CSS del contenedor.
  const root = document.querySelector<HTMLElement>('[data-landing]');
  const gallery = document.querySelector<HTMLElement>('[data-gallery]');
  if (root && gallery) {
    const cards = [...gallery.querySelectorAll<HTMLElement>('[data-accent]')];
    const MAP: ReadonlyArray<readonly [string, string]> = [
      ['accent', '--color-brand'],
      ['accentDark', '--color-brand-dark'],
      ['accentFg', '--color-brand-fg'],
      ['accentText', '--accent-text'],
      ['accentTextDark', '--accent-text-dark'],
      ['accentTextDm', '--accent-text-dm'],
    ];
    let active: HTMLElement | null = null;
    let raf = 0;
    const pick = () => {
      raf = 0;
      const box = gallery.getBoundingClientRect();
      const mid = box.left + box.width / 2;
      let best: HTMLElement | null = null;
      let dist = Infinity;
      for (const card of cards) {
        const r = card.getBoundingClientRect();
        const d = Math.abs(r.left + r.width / 2 - mid);
        if (d < dist) {
          dist = d;
          best = card;
        }
      }
      if (best && best !== active) {
        active = best;
        for (const [key, cssVar] of MAP) {
          const value = best.dataset[key];
          if (value) root.style.setProperty(cssVar, value);
        }
      }
    };
    gallery.addEventListener(
      'scroll',
      () => {
        raf ||= requestAnimationFrame(pick);
      },
      { passive: true },
    );
  }

  // 2 · Iris: la tarjeta se sirve como imagen (póster) y aquí se asciende a
  //     <video preload="none"> que reproduce solo mientras se ve. Nunca con
  //     reduced-motion ni con ahorro de datos: esos visitantes se quedan la
  //     imagen. El clip no baja ni un byte hasta que la tarjeta es visible.
  //     WCAG 2.2.2: todo lo que se mueve >5 s necesita pausa — el botón está
  //     en el template (oculto, fuera del enlace) y aquí solo se activa cuando
  //     el vídeo existe. Una pausa del visitante manda sobre el observer.
  const saveData =
    (navigator as Navigator & { connection?: { saveData?: boolean } }).connection?.saveData === true;
  if (!reduced && !saveData) {
    for (const img of document.querySelectorAll<HTMLImageElement>('img[data-video-src]')) {
      const video = document.createElement('video');
      video.className = img.className;
      video.poster = img.dataset.videoPoster ?? '';
      video.width = img.width;
      video.height = img.height;
      video.muted = true;
      video.loop = true;
      video.playsInline = true;
      video.preload = 'none';
      video.setAttribute('aria-label', img.alt);
      const source = document.createElement('source');
      source.src = img.dataset.videoSrc ?? '';
      source.type = 'video/mp4';
      video.appendChild(source);
      img.replaceWith(video);

      let userPaused = false;
      const toggle = video.closest('li')?.querySelector<HTMLButtonElement>('[data-video-toggle]');
      if (toggle) {
        const glyphPause = toggle.querySelector<SVGElement>('[data-glyph-pause]');
        const glyphPlay = toggle.querySelector<SVGElement>('[data-glyph-play]');
        toggle.addEventListener('click', () => {
          userPaused = !userPaused;
          if (userPaused) video.pause();
          else video.play().catch(() => {});
          glyphPause?.classList.toggle('hidden', userPaused);
          glyphPlay?.classList.toggle('hidden', !userPaused);
          toggle.setAttribute('aria-label', userPaused ? 'Reproducir la animación' : 'Pausar la animación');
          toggle.setAttribute('aria-pressed', String(userPaused));
        });
        toggle.hidden = false;
      }

      new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            const v = entry.target as HTMLVideoElement;
            if (entry.isIntersecting && !userPaused) v.play().catch(() => {});
            else v.pause();
          }
        },
        { threshold: 0.4 },
      ).observe(video);
    }
  }

  // 3 · Calculadora a 3 años. Mismas cuentas que la tabla estática (que queda
  //     como fallback sin JS): Shopify = 36 €/mes + 2 % de las ventas; Kit =
  //     1.900 € + 39 €/mes. Números en el pie de la sección.
  const calc = document.querySelector<HTMLElement>('[data-calc]');
  const calcStatic = document.querySelector<HTMLElement>('[data-calc-static]');
  const range = calc?.querySelector<HTMLInputElement>('input[type=range]');
  const outSales = calc?.querySelector<HTMLElement>('[data-out-sales]');
  const outShopify = calc?.querySelector<HTMLElement>('[data-out-shopify]');
  const outVerdict = calc?.querySelector<HTMLElement>('[data-out-verdict]');
  if (calc && calcStatic && range && outSales && outShopify && outVerdict) {
    const KIT_3Y = 1900 + 39 * 36;
    // Punto de miles siempre (coherente con «1.900 €» del copy; Intl es-ES no
    // agrupa por debajo de 10.000).
    const euros = (n: number) => `${n.toString().replace(/\B(?=(\d{3})+$)/g, '.')} €`;
    const update = () => {
      const sales = Number(range.value);
      const shopify = 36 * 36 + Math.round(sales * 0.02 * 36);
      const diff = shopify - KIT_3Y;
      outSales.textContent = euros(sales);
      outShopify.textContent = euros(shopify);
      outVerdict.textContent =
        diff >= 0
          ? `Con el Kit te ahorras ${euros(diff)} en 3 años — y el diseño a medida va incluido.`
          : `A este volumen, la cuota de Shopify sale ${euros(-diff)} más barata; el Kit compensa por el diseño a medida y las 2 h de cambios al mes.`;
    };
    range.addEventListener('input', update);
    update();
    calc.hidden = false;
    calcStatic.hidden = true;
  }
</script>
