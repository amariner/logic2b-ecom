---
// Página técnica de confianza: cómo funciona el sistema por dentro. Cero JS.
import Base from '../layouts/Base.astro';

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'TechArticle',
    headline: 'Arquitectura del Logic2B Commerce Kit',
    description:
      'Cómo funciona por dentro una tienda del Commerce Kit: Astro en el edge de Cloudflare, D1 como base de datos, Stripe Checkout y un flujo de envíos sin APIs de transportista.',
    author: { '@type': 'Organization', name: 'Logic2B' },
    inLanguage: 'es',
  },
];

const tables = [
  ['products', 'Catálogo: precio en céntimos, stock, categoría, activo'],
  ['orders', 'Pedido con totales congelados, estado y datos de envío'],
  ['order_items', 'Líneas con nombre y precio del momento de la compra'],
  ['order_events', 'Historial auditable de cada cambio de estado'],
  ['shipping_rates', 'Tarifa por zona con umbral de envío gratis'],
  ['emails_outbox', 'Cola de emails transaccionales'],
];

const benefits = [
  ['Factura de infraestructura: 0 €', 'Todo cabe en los planes gratuitos de Cloudflare; solo pagas dominio y la comisión estándar de Stripe.'],
  ['Sin cuellos de botella', 'Si sales en la radio y entran 5.000 personas a la vez, la tienda ni se entera: es HTML servido desde 300 ciudades.'],
  ['Sin rehenes', 'El código está en un repositorio a tu nombre. Si mañana quieres irte, te lo llevas todo.'],
];
---

<Base
  title="Arquitectura del Commerce Kit — así funciona por dentro | Logic2B"
  description="Astro estático en el edge, Cloudflare D1, Stripe Checkout con webhook idempotente y envíos por CSV a Packlink. La arquitectura completa de una tienda del Commerce Kit, explicada."
  canonicalPath="/arquitectura"
  jsonLd={jsonLd}
>
  <div class="bg-paper text-ink">
    <!-- Header sticky (mismo patrón que la landing) -->
    <header class="sticky top-0 z-40 border-b border-black/5 bg-white/85 backdrop-blur-md">
      <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-5">
        <a href="/" class="font-display text-lg">Logic2B<span class="text-brand">.</span></a>
        <nav class="flex items-center gap-3 text-sm sm:gap-6">
          <a href="/#precios" class="hidden text-stone-600 hover:text-ink sm:block">Precios</a>
          <a href="/#contacto" class="text-stone-600 hover:text-ink">Contacto</a>
          <a
            href="/demo/tienda"
            class="rounded-full bg-ink px-4 py-2 text-sm font-semibold text-white transition hover:bg-black sm:px-5"
          >Ver la demo</a>
        </nav>
      </div>
    </header>

    <main class="mx-auto max-w-3xl px-5 pb-20">
      <p class="mt-12 inline-block rounded-full border border-stone-200 bg-cream px-4 py-1.5 text-xs font-medium text-stone-600">
        Página técnica · La misma arquitectura que mueve la demo
      </p>
      <h1 class="mt-5 font-display text-4xl leading-[1.05] sm:text-5xl">Así funciona por dentro</h1>
      <p class="mt-5 text-lg leading-relaxed text-stone-600">
        Esta página existe porque la confianza se gana enseñando la cocina.
        Nada de humo: esta es la arquitectura exacta de cada tienda que entregamos,
        la misma que mueve la demo.
      </p>

      <h2 class="mt-14 font-display text-2xl sm:text-3xl">El principio: casi todo es estático</h2>
      <p class="mt-3 leading-relaxed text-stone-600">
        La tienda se genera como HTML puro y se sirve desde la red global de Cloudflare
        (300+ ciudades, la tuya incluida). Por eso carga en menos de medio segundo:
        no hay servidor pensando, solo ficheros viajando desde muy cerca del comprador.
        Las únicas piezas dinámicas son el carrito, el pago y el panel — funciones
        pequeñas que despiertan solo cuando se usan y se cobran por uso (uso que en
        una tienda de este tamaño cabe en el plan gratuito).
      </p>

      <h2 class="mt-14 font-display text-2xl sm:text-3xl">El flujo de una compra</h2>
      <!-- min-w evita que el texto del SVG se encoja por debajo de lo legible en
           móvil (el viewBox escala todo, etiquetas incluidas); overflow-x-auto
           deja desplazarlo en vez de recortarlo. -->
      <div class="mt-6 overflow-x-auto rounded-2xl border border-black/5 bg-cream p-4 sm:p-6">
        <svg viewBox="0 0 640 300" class="w-full min-w-[520px]" role="img" aria-label="Diagrama del flujo de compra: navegador, API en el edge, base de datos D1, Stripe y webhook">
          <defs>
            <marker id="arrow" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse">
              <path d="M 0 0 L 10 5 L 0 10 z" fill="#008060"></path>
            </marker>
          </defs>
          <g font-family="ui-sans-serif, system-ui, sans-serif" font-size="13">
            <rect x="10" y="20" width="150" height="52" rx="12" fill="#fff" stroke="#e7e5e4"></rect>
            <text x="85" y="42" text-anchor="middle" fill="#1a1a1a" font-weight="600">Comprador</text>
            <text x="85" y="60" text-anchor="middle" fill="#78716c" font-size="11">carrito en su navegador</text>

            <rect x="245" y="20" width="150" height="52" rx="12" fill="#fff" stroke="#e7e5e4"></rect>
            <text x="320" y="42" text-anchor="middle" fill="#1a1a1a" font-weight="600">API en el edge</text>
            <text x="320" y="60" text-anchor="middle" fill="#78716c" font-size="11">revalida precios y stock</text>

            <rect x="480" y="20" width="150" height="52" rx="12" fill="#fff" stroke="#e7e5e4"></rect>
            <text x="555" y="42" text-anchor="middle" fill="#1a1a1a" font-weight="600">Base de datos D1</text>
            <text x="555" y="60" text-anchor="middle" fill="#78716c" font-size="11">la única fuente de precios</text>

            <rect x="245" y="130" width="150" height="52" rx="12" fill="#1a1a1a"></rect>
            <text x="320" y="152" text-anchor="middle" fill="#ffffff" font-weight="600">Stripe Checkout</text>
            <text x="320" y="170" text-anchor="middle" fill="#a8a29e" font-size="11">la tarjeta nunca nos toca</text>

            <rect x="245" y="230" width="150" height="52" rx="12" fill="#fff" stroke="#008060"></rect>
            <text x="320" y="252" text-anchor="middle" fill="#1a1a1a" font-weight="600">Webhook firmado</text>
            <text x="320" y="270" text-anchor="middle" fill="#78716c" font-size="11">pagado → stock → email</text>

            <line x1="160" y1="46" x2="240" y2="46" stroke="#008060" stroke-width="1.5" marker-end="url(#arrow)"></line>
            <line x1="395" y1="46" x2="475" y2="46" stroke="#008060" stroke-width="1.5" marker-end="url(#arrow)"></line>
            <line x1="320" y1="72" x2="320" y2="125" stroke="#008060" stroke-width="1.5" marker-end="url(#arrow)"></line>
            <line x1="320" y1="182" x2="320" y2="225" stroke="#008060" stroke-width="1.5" marker-end="url(#arrow)"></line>
            <path d="M 395 256 C 560 256 555 130 555 77" fill="none" stroke="#008060" stroke-width="1.5" stroke-dasharray="4 3" marker-end="url(#arrow)"></path>
          </g>
        </svg>
      </div>
      <ol class="mt-6 list-decimal space-y-3 pl-5 leading-relaxed text-stone-600">
        <li>El carrito vive en el navegador del comprador, pero <strong class="text-ink">solo guarda referencias</strong>. Los precios se recalculan siempre en el servidor contra la base de datos: manipular el carrito no sirve de nada.</li>
        <li>Al pagar, la API revalida stock y precios y crea una sesión de <strong class="text-ink">Stripe Checkout</strong>. El comprador paga en la página de Stripe: el número de tarjeta jamás pasa por nuestra infraestructura.</li>
        <li>Stripe nos confirma el pago con un <strong class="text-ink">webhook firmado criptográficamente</strong>. Solo entonces el pedido pasa a «pagado», se descuenta el stock y se envía el email de confirmación — todo en una única transacción.</li>
        <li>Si Stripe reenvía la confirmación (pasa a menudo), el sistema la reconoce y no duplica nada: el webhook es <strong class="text-ink">idempotente</strong>.</li>
      </ol>

      <h2 class="mt-14 font-display text-2xl sm:text-3xl">El modelo de datos completo</h2>
      <p class="mt-3 leading-relaxed text-stone-600">
        Seis tablas. Sin ORM mágico, sin cincuenta relaciones. Dos decisiones importan:
        el dinero se guarda <strong class="text-ink">en céntimos enteros</strong> (nunca decimales flotantes)
        y cada línea de pedido <strong class="text-ink">congela el nombre y el precio</strong> del momento
        de la compra — cambiar una tarifa hoy jamás altera un pedido de ayer.
      </p>
      <div class="mt-5 overflow-hidden rounded-2xl border border-black/5 bg-white shadow-sm">
        <table class="w-full text-sm">
          <tbody class="divide-y divide-stone-100">
            {tables.map(([name, desc]) => (
              <tr>
                <td class="px-5 py-3 font-mono font-medium text-brand-dark">{name}</td>
                <td class="px-5 py-3 text-stone-600">{desc}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <h2 class="mt-14 font-display text-2xl sm:text-3xl">Envíos: simple a propósito</h2>
      <p class="mt-3 leading-relaxed text-stone-600">
        Nada de integraciones frágiles con APIs de transportistas. El comercio exporta
        los pedidos pagados en un CSV compatible con <strong class="text-ink">Packlink PRO o SendCloud</strong>,
        imprime las etiquetas allí (donde además el precio del envío es mejor), y pega el
        número de seguimiento en el panel. El cliente recibe su aviso automáticamente.
        Menos piezas, menos averías, y el mejor precio de etiqueta en cada momento.
      </p>

      <h2 class="mt-14 font-display text-2xl sm:text-3xl">Lo que esto significa para ti</h2>
      <div class="mt-6 grid gap-5 sm:grid-cols-3">
        {benefits.map(([title, body]) => (
          <div class="rounded-2xl border border-black/5 bg-white p-6 shadow-sm">
            <div class="flex h-10 w-10 items-center justify-center rounded-full bg-brand/10 text-brand">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
              </svg>
            </div>
            <h3 class="mt-4 font-semibold">{title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-stone-600">{body}</p>
          </div>
        ))}
      </div>

      <div class="mt-16 rounded-2xl bg-ink p-8 text-center text-white sm:p-10">
        <p class="font-display text-2xl sm:text-3xl">¿Quieres verlo funcionando?</p>
        <p class="mx-auto mt-3 max-w-md text-sm leading-relaxed text-stone-400">
          La demo es real: compra, recibe el email y gestiona el pedido en el panel.
        </p>
        <div class="mt-7 flex flex-col justify-center gap-3 sm:flex-row sm:gap-4">
          <a href="/demo/tienda" class="rounded-full bg-brand px-7 py-3 font-semibold text-white transition hover:bg-brand-dark">Tienda demo</a>
          <a href="/demo/admin" class="rounded-full border border-stone-600 px-7 py-3 font-semibold text-white transition hover:border-white">Panel del comercio</a>
        </div>
      </div>
    </main>

    <footer class="border-t border-black/5">
      <div class="mx-auto flex max-w-6xl flex-wrap items-center justify-between gap-2 px-5 py-6 text-sm text-stone-500">
        <p>© 2026 Logic2B · Castellón</p>
        <p><a href="/" class="hover:text-ink">Inicio</a> · <a href="/demo/tienda" class="hover:text-ink">Demo</a></p>
      </div>
    </footer>
  </div>
</Base>
