---
// Layout raíz. Landing/Shop/Admin heredan de aquí.
import '../styles/global.css';
import { jsonLdScript } from '../lib/format';
import { shopConfig } from '../../shop.config';

// El color de marca es única fuente de verdad en shop.config.ts (CLAUDE.md §11):
// lo inyectamos en :root para que TODAS las utilidades `*-brand` de Tailwind lo
// usen. `html:root` gana en especificidad al `:root` que emite @theme en
// global.css (que queda como fallback). Es CSS, no JS: la landing sigue cero-JS.
// En /demo/* el selector de temas sobreescribe con estilo inline en el elemento
// (mayor precedencia aún), así que sigue mandando sobre esto.
const brandTokens = `html:root{--color-brand:${shopConfig.brand.color};--color-brand-dark:${shopConfig.brand.colorDark}}`;

interface Props {
  title: string;
  description?: string | undefined;
  noindex?: boolean | undefined;
  /** Ruta canónica ("/", "/arquitectura"). Solo para páginas indexables. */
  canonicalPath?: string | undefined;
  /** JSON-LD ya serializable; se emite tal cual. */
  jsonLd?: object[] | undefined;
}

const { title, description = '', noindex = false, canonicalPath, jsonLd = [] } = Astro.props;
const canonical = canonicalPath ? new URL(canonicalPath, Astro.site).href : null;
const ogImage = new URL('/images/og.jpg', Astro.site).href;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <style set:html={brandTokens} is:inline></style>
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    {noindex && <meta name="robots" content="noindex,follow" />}
    {canonical && <link rel="canonical" href={canonical} />}
    <link rel="icon" href="/favicon.ico" sizes="48x48" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:type" content="website" />
    {canonical && <meta property="og:url" content={canonical} />}
    <meta property="og:locale" content="es_ES" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Logic2B Commerce Kit — tu tienda online sin cuotas de plataforma" />
    <meta name="twitter:card" content="summary_large_image" />
    {jsonLd.map((obj) => (
      <script type="application/ld+json" set:html={jsonLdScript(obj)} is:inline />
    ))}
  </head>
  <body class="min-h-screen bg-white text-gray-900 antialiased">
    <slot />
  </body>
</html>
