---
/**
 * Layout de tienda: noindex, banner de demo y CHROME del tema.
 *
 * 9B.4 — CADA TIENDA ES SU URL. El tema ya no sale de una cookie ni de un
 * selector: sale de la COLECCIÓN (prop), que a su vez sale del segmento de URL
 * validado contra el registro. Los tokens del tema se aplican en SSR como
 * variables CSS inline en el wrapper — sin localStorage, sin anti-flash, sin
 * recarga estructural. El backend es UNO solo para todas.
 */
import Base from './Base.astro';
import SiteHeader from '../components/SiteHeader.astro';
import MinimalHeader from '../components/themes/minimal/Header.astro';
import MinimalFooter from '../components/themes/minimal/Footer.astro';
import { shopConfig } from '../../shop.config';
import {
  DEFAULT_COLLECTION_ID,
  defaultCollection,
  storePaths,
  type CollectionConfig,
} from '../lib/collections';
import { defaultTheme, getTheme, type DemoTheme } from '../lib/demo-themes';

interface Props {
  title: string;
  description?: string;
  /** Tienda activa. Sin prop: la genérica (rutas históricas /demo/tienda…). */
  collection?: CollectionConfig;
}

const { title, description, collection = defaultCollection() } = Astro.props;

const theme: DemoTheme = getTheme(collection.themeId) ?? defaultTheme;
const paths = storePaths(collection.id);
const isDefaultStore = collection.id === DEFAULT_COLLECTION_ID;
const useSidebar = theme.layout.nav === 'sidebar';

// Tokens del tema aplicados en el wrapper (heredan por cascada). Base no
// necesita nada: sus valores son los de global.css.
const themeStyle =
  theme.id === defaultTheme.id
    ? undefined
    : Object.entries(theme.vars)
        .map(([k, v]) => `${k}: ${v}`)
        .join('; ');

const nav = isDefaultStore
  ? ([
      { href: paths.catalog, label: 'Tienda' },
      { href: '/demo/admin', label: 'Panel del comercio' },
    ] as const)
  : ([{ href: paths.catalog, label: 'Tienda' }] as const);
---

<Base title={`${title} — ${collection.name}`} description={description} noindex>
  <div
    data-store-theme={theme.id}
    data-store-collection={collection.id}
    style={themeStyle}
    class:list={[useSidebar && 'bg-surface-sunken']}
  >
    <div class="bg-foreground px-4 py-1.5 text-center text-xs text-background/80">
      <strong class="font-semibold text-background">Demo</strong> — tienda ficticia del
      <a href="/" class="underline decoration-background/40 underline-offset-2 hover:text-background">LogicEcom</a>.
      El pago está simulado: nada es real.
    </div>

    {useSidebar ? (
      <Fragment>
        {/* Hoja blanca insertada sobre gris claro, con nav lateral a la izquierda. */}
        <div class="mx-auto max-w-[1400px] bg-background">
          <div class="md:grid md:grid-cols-[13rem_minmax(0,1fr)]">
            <MinimalHeader collection={collection} paths={paths} />
            <div class="min-w-0"><slot /></div>
          </div>
        </div>
        <MinimalFooter collection={collection} paths={paths} />
      </Fragment>
    ) : (
      <Fragment>
        <SiteHeader homeHref={paths.catalog} wordmark={collection.name} showMark={false} nav={nav}>
          <a
            slot="actions"
            href={paths.cart}
            aria-label="Carrito"
            class="relative inline-flex items-center gap-1.5 rounded-btn bg-muted px-4 py-2 text-sm font-medium text-foreground transition hover:bg-secondary"
          >
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 0 0-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 0 0-16.536-1.84M7.5 14.25 5.106 5.272M6 20.25a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Zm12.75 0a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Z" />
            </svg>
            <span class="hidden sm:inline">Carrito</span>
            <span data-cart-badge class="hidden rounded-full bg-brand px-1.5 py-0.5 text-xs font-bold text-brand-fg">0</span>
          </a>
        </SiteHeader>

        <slot />

        <footer class="mt-20 border-t border-border bg-muted">
          <div class="mx-auto max-w-6xl px-4 py-10 text-sm text-muted-foreground">
            <p class="font-display text-base text-foreground">{collection.name}</p>
            <p class="mt-3 max-w-2xl leading-relaxed">{shopConfig.legalName}. {shopConfig.legal.shippingNote} {shopConfig.legal.returnsNote}</p>
            <p class="mt-4">Demo de <a href="/" class="underline underline-offset-2 hover:text-foreground">LogicEcom</a> · <a href="/demo/reset" class="underline underline-offset-2 hover:text-foreground">Restaurar datos de la demo</a></p>
          </div>
        </footer>
      </Fragment>
    )}
  </div>

  <script>
    import { bindCartBadge, cartCount } from '../lib/cart-client';

    const badge = document.querySelector<HTMLElement>('[data-cart-badge]');
    if (badge) bindCartBadge(badge);

    // CART (n) del sidebar Minimal: el número se muestra SIEMPRE (incluido 0),
    // a diferencia del badge de Base (que se oculta cuando el carrito va vacío).
    const countEls = [...document.querySelectorAll<HTMLElement>('[data-cart-count]')];
    if (countEls.length > 0) {
      const renderCount = (): void => {
        const n = String(cartCount());
        for (const el of countEls) el.textContent = n;
      };
      renderCount();
      document.addEventListener('cart:changed', renderCount);
    }
  </script>

  {shopConfig.analytics.cfBeaconToken && (
    <script
      defer
      src="https://static.cloudflareinsights.com/beacon.min.js"
      data-cf-beacon={JSON.stringify({ token: shopConfig.analytics.cfBeaconToken })}
      is:inline
    ></script>
  )}
</Base>
