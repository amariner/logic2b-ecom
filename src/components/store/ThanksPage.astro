---
/**
 * Confirmación post-pago de UNA tienda — página compartida (9B.4).
 */
import Shop from '../../layouts/Shop.astro';
import { DEFAULT_COLLECTION_ID, storePaths, type CollectionConfig } from '../../lib/collections';
import { formatEurCents } from '../../lib/format';

type OrderRow = {
  order_number: string;
  customer_name: string;
  email: string;
  status: string;
  total_cents: number;
};

interface Props {
  collection: CollectionConfig;
  order: OrderRow | null;
}

const { collection, order } = Astro.props;
const paths = storePaths(collection.id);
const isDefaultStore = collection.id === DEFAULT_COLLECTION_ID;
---

<Shop title="Gracias" description="Confirmación de pedido" collection={collection}>
  <main class="mx-auto max-w-xl px-4 py-16 text-center">
    {order ? (
      <>
        <p class="text-5xl" aria-hidden="true">🧺</p>
        <h1 class="mt-4 font-display text-3xl text-foreground sm:text-4xl">¡Gracias, {order.customer_name.split(' ')[0]}!</h1>
        <p class="mt-3 text-muted-foreground">
          Tu pedido <strong>{order.order_number}</strong> por {formatEurCents(order.total_cents)} está
          {order.status === 'paid' ? ' confirmado' : ' registrándose (el pago se está procesando)'}.
        </p>
        <p class="mt-2 text-sm text-muted-foreground">Hemos enviado la confirmación a {order.email}.</p>

        {isDefaultStore && (
          <div class="mt-8 rounded-2xl bg-muted p-6 text-left">
            <p class="text-sm font-semibold uppercase tracking-wide text-brand">Sigue el recorrido de la demo</p>
            <ol class="mt-4 space-y-4 text-sm leading-relaxed text-muted-foreground">
              <li class="flex gap-3">
                <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-brand font-bold text-brand-fg" aria-hidden="true">✓</span>
                <span><strong>Has comprado.</strong> El pedido ya existe de verdad: con stock descontado, estado «pagado» y su historial.</span>
              </li>
              <li class="flex gap-3">
                <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-foreground font-bold text-background" aria-hidden="true">2</span>
                <span>
                  <strong>Gestiónalo como el comercio:</strong> entra en el
                  <a href="/demo/admin" class="text-brand underline underline-offset-2 hover:text-brand-dark">panel de pedidos</a>
                  (contraseña <span class="font-mono">demo</span>) y márcalo como enviado con un tracking inventado.
                </span>
              </li>
              <li class="flex gap-3">
                <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-foreground font-bold text-background" aria-hidden="true">3</span>
                <span>
                  <strong>Mira los emails</strong> que el sistema habría enviado (confirmación y aviso de envío) en la
                  <a href="/demo/admin/emails" class="text-brand underline underline-offset-2 hover:text-brand-dark">bandeja simulada</a>.
                </span>
              </li>
            </ol>
          </div>
        )}
      </>
    ) : (
      <>
        <h1 class="font-display text-3xl text-foreground">No encontramos ese pedido</h1>
        <p class="mt-3 text-muted-foreground">Si acabas de pagar, dale unos segundos y recarga.</p>
      </>
    )}
    <a href={paths.catalog} class="mt-8 inline-block rounded-btn bg-brand px-7 py-3 font-semibold text-brand-fg transition hover:bg-brand-dark">Volver a la tienda</a>
  </main>

  <script>
    import { clearCart } from '../../lib/cart-client';
    // El pedido ya está registrado en servidor; el carrito local ya no aplica.
    if (document.querySelector('main strong')) clearCart();
  </script>
</Shop>
