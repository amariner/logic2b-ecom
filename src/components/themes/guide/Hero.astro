---
/**
 * GUIDE · Hero — la tarjeta grande de cabecera (`layout.hero: 'card'`).
 *
 * Título + descripción arriba a la izquierda, nav de categorías como radio
 * buttons arriba a la derecha, y una fila de pie con dos apuntes. Entre medias,
 * MUCHO VACÍO: es intencional en la referencia (Pour over) y no se rellena.
 */
import Filters from './Filters.astro';

interface Props {
  activeCategory?: string | undefined;
  categoryLabel?: string | undefined;
  sort: string;
  search?: string | undefined;
}

const { activeCategory, categoryLabel, sort, search } = Astro.props;
---

<section
  class="flex min-h-[22rem] flex-col bg-card px-6 py-8 shadow-sm sm:min-h-[26rem] sm:px-10 sm:py-10 lg:min-h-[30rem]"
  style="border-radius: var(--radius-card);"
>
  <div class="flex flex-col gap-8 lg:flex-row lg:items-start lg:justify-between lg:gap-16">
    <div class="max-w-xl">
      <h1 class="font-display text-3xl text-foreground sm:text-4xl">
        La despensa del Maestrat <span aria-hidden="true">🫒</span>
      </h1>
      <p class="mt-5 text-base leading-relaxed text-muted-foreground sm:text-lg">
        Guía de producto de la tierra: aceites, embutidos, mieles, vinos, conservas y
        quesos. Cada pieza con su origen, su temporada y quien la elabora.
      </p>
    </div>

    <div class="shrink-0 lg:pt-2">
      <Filters activeCategory={activeCategory} sort={sort} search={search} />
    </div>
  </div>

  <div class="mt-auto flex flex-wrap items-end justify-between gap-x-6 gap-y-2 pt-12 text-sm text-muted-foreground">
    <a href="/arquitectura" class="transition-colors hover:text-foreground">Cómo funciona</a>
    <p>
      {categoryLabel ? `Estás viendo: ${categoryLabel}.` : 'Producto pequeño, bien hecho. Sin prisa.'}
    </p>
  </div>
</section>
