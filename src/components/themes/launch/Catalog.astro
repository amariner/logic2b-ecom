---
/**
 * LAUNCH · Catalog — vista completa del catálogo para el tema, montada por la
 * página (src/pages/demo/tienda/index.astro) a través del registro de temas.
 *
 * Planteamiento de LANDING de lanzamiento (referencia P1), no de catálogo
 * denso. Con 60 productos y 3 columnas el formato "encaja mal" (nota de
 * docs/TEMAS.md), así que se resuelve por composición, sin inventar datos:
 *
 *  · Vista prístina (sin categoría, sin búsqueda, orden por defecto): hero con
 *    titular grande y ligero + fila de LANZAMIENTO con scroll horizontal (los
 *    primeros productos del orden de catálogo) + el resto en rejilla normal +
 *    banda de tarjetas de confianza.
 *  · Con filtros, búsqueda u orden activos: catálogo funcional directo (chips +
 *    rejilla completa), sin bandas de landing.
 *
 * La barra sticky inferior con el ESTADO REAL DE STOCK (D1) acompaña siempre.
 */
import type { CollectionConfig } from '../../../lib/collections';
import Filters from './Filters.astro';
import ProductGrid from './ProductGrid.astro';
import FeatureScroller from './FeatureScroller.astro';
import InfoCards from './InfoCards.astro';
import StickyBar from './StickyBar.astro';

type GridProduct = {
  slug: string;
  name: string;
  description: string;
  price_cents: number;
  image: string;
  stock: number;
};

interface Props {
  products: GridProduct[];
  collection: CollectionConfig;
  category?: string | undefined;
  sort: string;
  search?: string | undefined;
}

const { products, collection, category, sort, search } = Astro.props;

// Composición de landing solo en la vista prístina del catálogo.
const landing = !category && !search && sort === 'featured' && products.length > 0;
const FEATURED_COUNT = 4;
const featured = landing ? products.slice(0, FEATURED_COUNT) : [];
const gridProducts = landing ? products.slice(FEATURED_COUNT) : products;

// Producto estrella de la barra sticky: el primero del orden de catálogo con
// stock (o el primero a secas, para poder enseñar también el estado "agotado").
const star = products.find((p) => p.stock > 0) ?? products[0];
---

<div class="bg-background">
  {landing && (
    <section class="bg-muted">
      <div class="mx-auto max-w-6xl px-4 pb-16 pt-14 sm:px-6">
        <h1 class="max-w-3xl font-display text-4xl leading-tight text-foreground sm:text-5xl lg:text-6xl">
          La nueva temporada del Maestrat. Pocas piezas, muy escogidas.
        </h1>
        <a
          href="#catalogo"
          class="mt-7 inline-flex items-center gap-2.5 text-sm font-medium text-foreground transition-colors hover:text-brand"
        >
          <svg class="h-9 w-9" fill="none" viewBox="0 0 24 24" stroke-width="1.2" stroke="currentColor" aria-hidden="true">
            <circle cx="12" cy="12" r="10.5" />
            <path stroke-linecap="round" stroke-linejoin="round" d="m10 8.5 5 3.5-5 3.5v-7Z" />
          </svg>
          Ver todo el catálogo
        </a>

        <h2 class="sr-only">Novedades del lanzamiento</h2>
        <FeatureScroller products={featured} />
      </div>
    </section>
  )}

  <main id="catalogo" class="mx-auto max-w-6xl px-4 py-12 sm:px-6">
    {landing ? (
      <h2 class="font-display text-3xl text-foreground sm:text-4xl">Todo el catálogo</h2>
    ) : (
      <h1 class="font-display text-3xl text-foreground sm:text-4xl">Catálogo</h1>
    )}

    <div class="mt-7">
      <Filters collection={collection} count={products.length} activeCategory={category} sort={sort} search={search} />
    </div>

    <div class="mt-8">
      {gridProducts.length > 0 ? (
        <ProductGrid products={gridProducts} />
      ) : (
        <div
          class="px-6 py-20 text-center"
          style="border: var(--border-width) solid var(--color-border); border-radius: var(--radius-card);"
        >
          <p class="font-display text-2xl text-foreground">
            {search ? `Nada por aquí para «${search}»` : 'No hay productos en esta categoría'}
          </p>
          <p class="mx-auto mt-2 max-w-md text-sm leading-relaxed text-muted-foreground">
            {search
              ? 'Prueba con otra palabra (por ejemplo «aceite», «miel» o «queso») o vuelve al catálogo completo.'
              : 'Puede que el comercio la haya vaciado temporalmente. El resto del catálogo sigue disponible.'}
          </p>
          <a
            href="/demo/tienda"
            class="mt-6 inline-block bg-brand px-6 py-2.5 text-sm font-medium text-brand-fg transition hover:bg-brand-dark"
            style="border-radius: var(--radius-btn);"
          >Ver todo el catálogo</a>
        </div>
      )}
    </div>
  </main>

  {landing && (
    <section class="mx-auto max-w-6xl px-4 pb-16 sm:px-6" aria-label="Envío y garantías">
      <h2 class="font-display text-3xl text-foreground sm:text-4xl">Comprar aquí es así de simple</h2>
      <div class="mt-8">
        <InfoCards />
      </div>
    </section>
  )}

  {star && <StickyBar product={star} />}
</div>
