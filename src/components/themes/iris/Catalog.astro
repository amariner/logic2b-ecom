---
/**
 * IRIS · Catalog — tienda inmersiva importada del proyecto logic2b-norte
 * (spec propio «Orven», rebrandeado a Iris).
 *
 * Vídeo de fondo escrutado fotograma a fotograma con el scroll, hero editorial
 * con ficha en cristal esmerilado y slider de catálogo. Adaptación al motor:
 * los productos salen de D1 (props), la insignia es la capacidad `subtitle`,
 * el botón de carrito añade de verdad (`data-iris-add`) y los enlaces usan
 * `paths`. CSS y JS inline, cero librerías; assets autoalojados en
 * /images/collections/iris/. `nav: 'immersive'`: el layout no monta chrome.
 */
import type { CollectionConfig, StorePaths } from '../../../lib/collections';
import { formatEurCents } from '../../../lib/format';

type GridProduct = {
  slug: string;
  name: string;
  description: string;
  price_cents: number;
  image: string;
  stock: number;
  subtitle?: string | null;
};

interface Props {
  paths: StorePaths;
  products: GridProduct[];
  collection: CollectionConfig;
  category?: string | undefined;
  sort: string;
  search?: string | undefined;
}

const { paths, products, collection } = Astro.props;

const VIDEO = '/images/collections/iris/hero.mp4';
const POSTER = '/images/collections/iris/hero-poster.jpg';
const hero = products[0];
---

<div class="iris" id="iris-root">
  <video
    class="iris-bg-video"
    poster={POSTER}
    muted
    playsinline
    crossorigin="anonymous"
    preload="auto"
    data-src={VIDEO}
    aria-hidden="true"
  ></video>

  <header class="iris-header">
    <div class="iris-header__logo-col">
      <a class="iris-header__logo" href={paths.catalog}>{collection.name}®</a>
    </div>
    <div class="iris-header__col">
      <span class="iris-header__line">Ingeniería de precisión</span>
      <span class="iris-header__line">Esencial</span>
      <span class="iris-header__line">Probado</span>
    </div>
    <div class="iris-header__col">
      <span class="iris-header__line">Innovación redefinida</span>
      <a class="iris-header__line" href="/">Nuestra historia</a>
    </div>
    <div class="iris-header__col iris-header__col--end">
      <a class="iris-header__line" href={paths.cart}>+ Carrito (<span data-cart-count>0</span>)</a>
    </div>
  </header>

  <div class="iris-scroll-track">
    <section class="iris-hero iris-grid">
      <div class="iris-title-caption">
        <h1 class="iris-title">{collection.name}®</h1>
        <p class="iris-title-caption__text">
          Óptica de alto rendimiento diseñada para una visión nítida. Lentes de precisión
          probadas para durar. Tecnología superior, construida para la excelencia.
        </p>
      </div>
      {hero && (
        <div class="iris-product-card">
          <div class="iris-product-card__row">
            <img class="iris-product-card__img" src={hero.image} alt={hero.name} loading="lazy" />
            <div class="iris-product-card__body">
              <p class="iris-product-card__text">
                Óptica espejada de firma en titanio ingrávido. Explora la colección completa.
              </p>
              <a class="iris-product-card__btn" href="#iris-catalogo">DESCUBRIR</a>
            </div>
          </div>
        </div>
      )}
    </section>
  </div>

  <section class="iris-products" id="iris-catalogo">
    <div class="iris-products__header">
      <h2 class="iris-products__title">Colección de rendimiento</h2>
      <a class="iris-products__link" href={paths.cart}>Ver carrito</a>
    </div>
    <div class="iris-products__slider">
      {products.map((p) => (
        <article class="iris-card">
          <div class="iris-card__img">
            {p.subtitle && <span class="iris-card__badge">{p.subtitle}</span>}
            <img src={p.image} alt={p.name} loading="lazy" />
          </div>
          <div class="iris-card__info">
            <a class="iris-card__copy" href={paths.product(p.slug)}>
              <p class="iris-card__name">{p.name}</p>
              <p class="iris-card__desc">{p.description}</p>
            </a>
            <div class="iris-card__bottom">
              <span class="iris-card__price">{formatEurCents(p.price_cents)}</span>
              <button
                class="iris-card__cart"
                type="button"
                data-iris-add={p.slug}
                disabled={p.stock === 0}
                aria-label={p.stock === 0 ? `${p.name} agotado` : `Añadir ${p.name} al carrito`}
              >
                <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor" aria-hidden="true">
                  <path d="M8 6a4 4 0 1 1 8 0v1h2.2a1 1 0 0 1 1 .88l1.5 12A1.5 1.5 0 0 1 20.2 22H3.8a1.5 1.5 0 0 1-1.5-2.12l1.5-12A1 1 0 0 1 4.8 7H8V6Zm2 1h4V6a2 2 0 1 0-4 0v1Zm2 4.25a.9.9 0 0 0-.9.9v1.6h-1.6a.9.9 0 0 0 0 1.8h1.6v1.6a.9.9 0 0 0 1.8 0v-1.6h1.6a.9.9 0 0 0 0-1.8h-1.6v-1.6a.9.9 0 0 0-.9-.9Z"/>
                </svg>
              </button>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>
</div>

<script>
  import { addToCart } from '../../../lib/cart-client';

  document.querySelectorAll<HTMLButtonElement>('[data-iris-add]').forEach((btn) => {
    btn.addEventListener('click', () => {
      addToCart(btn.dataset.irisAdd ?? '');
      btn.classList.add('is-added');
      setTimeout(() => btn.classList.remove('is-added'), 600);
    });
  });
</script>

<script>
  (() => {
    const root = document.querySelector('#iris-root');
    if (!root) return;

    const video = root.querySelector('.iris-bg-video') as HTMLVideoElement | null;
    const scrollTrack = root.querySelector('.iris-scroll-track') as HTMLElement | null;
    const products = root.querySelector('.iris-products') as HTMLElement | null;
    const cards = Array.from(root.querySelectorAll<HTMLElement>('.iris-card'));
    if (!video || !scrollTrack || !products) return;
    const VIDEO_SRC = video.getAttribute('data-src') || '';
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    document.documentElement.style.overscrollBehavior = 'none';
    if (document.body) document.body.style.overscrollBehavior = 'none';

    if (reduceMotion) {
      root.classList.add('is-reduced-motion');
      cards.forEach((c) => c.style.setProperty('--py', '0px'));
      video.src = VIDEO_SRC;
      return;
    }

    // ——— Motor de scrub de vídeo ———
    // Un solo seek en vuelo. El scroll solo escribe `target`; el rAF interpola
    // `current` hacia `target` con lerp y solo hace seek cuando !video.seeking.
    const LERP = 0.12;
    const SEEK_EPS = 0.04;
    let target = 0;
    let current = 0;
    let rafId = 0;
    let ready = false;

    const clamp = (v: number, min = 0, max = 1) => Math.max(min, Math.min(max, v));

    function trackProgress() {
      if (!scrollTrack) return 0;
      const trackEnd = scrollTrack.offsetHeight - window.innerHeight;
      if (trackEnd <= 0) return 0;
      return clamp(window.scrollY / trackEnd);
    }

    function syncTarget() {
      if (!ready || !video || !video.duration) return;
      target = trackProgress() * video.duration;
      startLoop();
    }

    function startLoop() {
      if (rafId) return;
      rafId = requestAnimationFrame(tick);
    }

    function tick() {
      rafId = 0;
      if (!video) return;
      current += (target - current) * LERP;
      if (!video.seeking && Math.abs(video.currentTime - current) > SEEK_EPS) {
        video.currentTime = current;
      }
      const lerping = Math.abs(target - current) > 0.001;
      const behind = Math.abs(video.currentTime - current) > SEEK_EPS;
      if (lerping || video.seeking || behind) {
        rafId = requestAnimationFrame(tick);
      } else {
        current = target;
      }
    }

    video.addEventListener('seeked', () => {
      if (!video.seeking && Math.abs(video.currentTime - current) > SEEK_EPS) {
        video.currentTime = current;
      }
      startLoop();
    });

    window.addEventListener('scroll', syncTarget, { passive: true });
    window.addEventListener('resize', syncTarget);

    async function loadAndPrime() {
      if (!video) return;
      // Descarga completa → blob URL: los seeks golpean bytes locales, no la red.
      try {
        const res = await fetch(VIDEO_SRC);
        const blob = await res.blob();
        video.src = URL.createObjectURL(blob);
      } catch {
        video.src = VIDEO_SRC;
      }
      await new Promise<void>((resolve) => {
        if (video.readyState >= 1) resolve();
        else video.addEventListener('loadedmetadata', () => resolve(), { once: true });
      });
      try { await video.play(); } catch { /* autoplay puede bloquearse */ }
      video.pause();
      video.currentTime = 0;
      ready = true;
      syncTarget();
      startLoop();
    }
    void loadAndPrime();

    // ——— Revelado de producto (parallax al entrar en viewport) ———
    const targetY: number[] = new Array(cards.length).fill(80);
    const currentY: number[] = new Array(cards.length).fill(80);
    const REVEAL_EASE = 0.08;
    let revealRaf = 0;

    function revealNeedsWork() {
      for (let i = 0; i < cards.length; i++) {
        if (Math.abs((targetY[i] ?? 0) - (currentY[i] ?? 0)) > 0.05) return true;
      }
      return false;
    }
    function startRevealLoop() {
      if (revealRaf) return;
      revealRaf = requestAnimationFrame(tickReveal);
    }
    function updateReveal() {
      if (!products) return;
      const rect = products.getBoundingClientRect();
      const viewH = window.innerHeight;
      const p = clamp((viewH - rect.top) / (viewH - viewH * 0.3));
      cards.forEach((_, i) => {
        const cardP = clamp(p * 1.5 - i * 0.08);
        targetY[i] = (1 - cardP) * 80;
      });
      startRevealLoop();
    }
    function tickReveal() {
      revealRaf = 0;
      cards.forEach((c, i) => {
        currentY[i] = (currentY[i] ?? 0) + ((targetY[i] ?? 0) - (currentY[i] ?? 0)) * REVEAL_EASE;
        c.style.setProperty('--py', `${(currentY[i] ?? 0).toFixed(2)}px`);
      });
      if (revealNeedsWork()) revealRaf = requestAnimationFrame(tickReveal);
    }
    window.addEventListener('scroll', updateReveal, { passive: true });
    window.addEventListener('resize', updateReveal);
    updateReveal();
  })();
</script>

<style>
  .iris {
    /* Tokens propios del tema (importados de logic2b-norte/tokens.css).
       El acento y la tipografía leen los tokens del sistema de temas. */
    --ir-gap: 12px;
    --ir-margin: 16px;
    --ir-header-h: 56px;
    --ir-accent: var(--color-brand, #e6074e);
    --ir-white: #ffffff;
    --ir-black: #000000;
    --ir-font: var(--font-display, 'Inter Tight', sans-serif);
    --ir-ease-expo: cubic-bezier(0.16, 1, 0.3, 1);

    position: relative;
    background: var(--ir-black);
    font-family: var(--ir-font);
    font-weight: 500;
    color: var(--ir-accent);
    overflow-x: hidden;
    -webkit-font-smoothing: antialiased;
  }
  .iris :global(*), .iris :global(*::before), .iris :global(*::after) { box-sizing: border-box; }
  .iris :where(button) { font: inherit; }
  .iris :where(a) { color: inherit; text-decoration: none; }
  .iris h1, .iris h2, .iris p { margin: 0; }

  /* ——— Vídeo de fondo ——— */
  .iris-bg-video {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(1.12);
    transform-origin: center center;
  }

  /* ——— Header ——— */
  .iris-header {
    position: fixed;
    /* top despeja el banner fijo de la demo */
    inset: 44px 0 auto;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-inline: var(--ir-margin);
    min-height: 40px;
    pointer-events: none;
  }
  .iris-header > * { pointer-events: auto; }
  .iris-header__logo-col { display: flex; align-items: center; }
  .iris-header__logo { font-size: 18px; line-height: 1; letter-spacing: -0.04em; }
  .iris-header__col { display: none; }
  .iris-header__col--end { display: flex; align-items: center; border: none; padding: 0; height: auto; }
  .iris-header__line { font-size: 13px; line-height: 1; letter-spacing: -0.03em; }
  .iris-header__col--end .iris-header__line { text-align: right; }

  /* ——— Hero (móvil: hoja apilada abajo) ——— */
  .iris-scroll-track { position: relative; z-index: 1; height: 420vh; }
  .iris-grid { display: grid; grid-template-columns: 1fr; gap: 16px; padding-inline: var(--ir-margin); }
  .iris-hero {
    position: sticky;
    top: 0;
    height: 100svh;
    height: 100dvh;
    align-content: end;
    padding-top: calc(var(--ir-header-h) + 8px);
    padding-bottom: max(20px, env(safe-area-inset-bottom));
  }
  .iris-title-caption { display: flex; flex-direction: column; gap: 10px; max-width: 100%; }
  .iris-title { font-weight: 500; font-size: clamp(52px, 17vw, 72px); line-height: 0.92; letter-spacing: -0.05em; }
  .iris-title-caption__text {
    font-size: 14px; line-height: 1.35; letter-spacing: -0.03em;
    max-width: 28em; opacity: 0.95;
  }

  .iris-product-card {
    display: flex; width: 100%; padding: 12px;
    background: rgba(255, 255, 255, 0.18);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-radius: 18px;
    border: 1px solid rgba(255, 255, 255, 0.12);
  }
  .iris-product-card__row { display: flex; gap: 12px; width: 100%; align-items: stretch; }
  .iris-product-card__img { width: 84px; height: 84px; border-radius: 14px; object-fit: cover; flex: none; }
  .iris-product-card__body {
    display: flex; flex-direction: column; justify-content: space-between;
    align-items: stretch; gap: 8px; flex: 1; min-width: 0;
  }
  .iris-product-card__text { font-size: 13px; line-height: 1.3; letter-spacing: -0.03em; color: var(--ir-accent); }
  .iris-product-card__btn {
    display: inline-flex; align-items: center; justify-content: center; align-self: flex-end;
    min-height: 40px; padding: 8px 18px;
    background: var(--ir-accent); border-radius: 999px; border: none; cursor: pointer;
    font-weight: 500; font-size: 13px; line-height: 1.2; letter-spacing: -0.03em;
    color: #fff; -webkit-tap-highlight-color: transparent;
    transition: transform 0.3s var(--ir-ease-expo), opacity 0.3s var(--ir-ease-expo);
  }
  .iris-product-card__btn:hover { transform: translateY(-1px); opacity: 0.9; }

  /* ——— Productos ——— */
  .iris-products {
    position: relative; z-index: 2; background: #fff;
    padding: 36px 0 48px; display: flex; flex-direction: column; justify-content: center;
  }
  .iris-products__header {
    display: flex; justify-content: space-between; align-items: baseline;
    gap: 16px; margin-bottom: 18px; padding-inline: var(--ir-margin);
  }
  .iris-products__title { font-size: 17px; font-weight: 500; letter-spacing: -0.02em; color: #000; }
  .iris-products__link {
    font-size: 13px; font-weight: 500; color: #000;
    text-decoration: underline; text-underline-offset: 3px; white-space: nowrap;
  }
  .iris-products__slider {
    display: flex; gap: 10px; overflow-x: auto; padding-left: var(--ir-margin);
    overscroll-behavior-x: contain; scroll-snap-type: x mandatory;
    scrollbar-width: none; -webkit-overflow-scrolling: touch;
  }
  .iris-products__slider::-webkit-scrollbar { display: none; }
  .iris-products__slider::after { content: ''; flex: 0 0 var(--ir-margin); }
  .iris-card { flex: 0 0 min(78vw, 280px); scroll-snap-align: start; --py: 0px; }
  .iris-card__img, .iris-card__info { transform: translateY(var(--py)); will-change: transform; }
  .iris-card__img {
    aspect-ratio: 1 / 1; background: var(--surface-product, #f7f5f5); border-radius: 18px;
    position: relative; overflow: hidden; display: flex; align-items: center; justify-content: center;
  }
  .iris-card__badge {
    position: absolute; top: 10px; left: 10px; background: #000; color: #fff;
    font-size: 11px; padding: 4px 8px; border-radius: 2px; letter-spacing: -0.01em; z-index: 1;
  }
  .iris-card__img img { width: 78%; height: 78%; object-fit: contain; border-radius: 16px; }
  .iris-card__info { padding: 12px 4px 4px; display: flex; flex-direction: column; gap: 14px; }
  .iris-card__copy { text-decoration: none; display: flex; flex-direction: column; gap: 4px; }
  .iris-card__name { font-size: 14px; font-weight: 500; color: #000; letter-spacing: -0.01em; }
  .iris-card__desc { font-size: 13px; font-weight: 400; color: #888; line-height: 1.4; letter-spacing: -0.01em; }
  .iris-card__bottom { display: flex; justify-content: space-between; align-items: center; }
  .iris-card__price { font-size: 14px; font-weight: 500; color: #000; }
  .iris-card__cart {
    background: transparent; border: none; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    width: 44px; height: 44px; margin: -10px -8px -10px 0;
    color: var(--ir-accent); -webkit-tap-highlight-color: transparent;
    transition: transform 0.3s var(--ir-ease-expo);
  }
  .iris-card__cart:hover { transform: scale(1.12); }
  .iris-card__cart.is-added { transform: scale(1.3); }
  .iris-card__cart:disabled { color: #ccc; cursor: not-allowed; }

  /* ——— Tablet+ ——— */
  @media (min-width: 640px) {
    .iris { --ir-margin: 24px; --ir-gap: 16px; }
    .iris-title { font-size: clamp(72px, 12vw, 96px); }
    .iris-title-caption__text { font-size: 15px; max-width: 34em; }
    .iris-product-card { padding: 14px; border-radius: 20px; }
    .iris-product-card__img { width: 100px; height: 100px; border-radius: 16px; }
    .iris-product-card__text { font-size: 15px; }
    .iris-product-card__btn { font-size: 15px; min-height: 42px; padding: 8px 24px; }
    .iris-card { flex: 0 0 min(46vw, 320px); }
    .iris-header__logo { font-size: 20px; }
    .iris-scroll-track { height: 460vh; }
  }

  /* ——— Desktop ——— */
  @media (min-width: 960px) {
    .iris { --ir-gap: 24px; --ir-margin: 32px; }
    .iris-bg-video { transform: scale(1.35); }

    .iris-header {
      top: 52px; inset: 52px 0 auto; align-items: flex-start;
      padding-inline: 32px; min-height: 58px;
    }
    .iris-header__logo-col { flex: 1 1 0; height: 58px; }
    .iris-header__logo { font-size: 24px; }
    .iris-header__col {
      display: flex; flex: 1 1 0; flex-direction: column; align-items: flex-start;
      gap: 8px; height: 58px; padding: 0 24px;
    }
    .iris-header__col--end { align-items: flex-end; padding: 0 0 0 24px; }
    .iris-header__line { font-size: 14px; }

    .iris-scroll-track { height: 500vh; }
    .iris-grid { grid-template-columns: repeat(12, 1fr); column-gap: var(--ir-gap); row-gap: 0; padding-inline: var(--ir-margin); }
    .iris-hero { height: 100vh; align-content: end; padding-top: 0; padding-bottom: 60px; }
    .iris-title-caption { grid-column: 1 / 7; align-self: end; gap: 0; }
    .iris-title { font-size: clamp(96px, 11vw, 160px); line-height: 100%; letter-spacing: -0.04em; }
    .iris-title-caption__text { font-size: 18px; line-height: 120%; letter-spacing: -0.04em; text-indent: 120px; max-width: none; }

    .iris-product-card {
      grid-column: 9 / 13; align-self: end; width: 100%; max-width: 453px; height: 150px;
      padding: 16px; border-radius: 24px; border: none; justify-self: end;
    }
    .iris-product-card__row { gap: 24px; }
    .iris-product-card__img { width: 118px; height: 118px; border-radius: 24px; }
    .iris-product-card__body { align-items: flex-end; gap: 8px; }
    .iris-product-card__text { font-size: 18px; line-height: 120%; letter-spacing: -0.04em; text-indent: 120px; }
    .iris-product-card__btn { font-size: 18px; padding: 8px 32px; min-height: 0; }

    .iris-products { padding: 60px 0 60px 32px; min-height: 100vh; }
    .iris-products__header { margin-bottom: 30px; padding-inline: 0 32px; }
    .iris-products__title { font-size: 21px; }
    .iris-products__link { font-size: 14px; }
    .iris-products__slider { padding-left: 0; gap: 10px; }
    .iris-products__slider::after { flex-basis: 22px; }
    .iris-card { flex: 0 0 calc((100vw - 102px) / 3); }
    .iris-card__img { aspect-ratio: 13 / 12; border-radius: 24px; }
    .iris-card__info { padding: 15px 10px 10px; gap: 20px; }
    .iris-card__desc { font-size: 14px; }
    .iris-card__cart { width: auto; height: auto; margin: 0; }
    .iris-card__cart svg { width: 24px; height: 24px; }
  }

  @media (min-width: 1280px) {
    .iris-title { font-size: 160px; }
  }

  /* Móviles bajos: hero siempre visible */
  @media (max-width: 959px) and (max-height: 700px) {
    .iris-hero { gap: 12px; padding-bottom: 16px; }
    .iris-title { font-size: clamp(44px, 14vw, 60px); }
    .iris-title-caption__text { display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
    .iris-product-card__text { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .iris-product-card__img { width: 72px; height: 72px; }
  }

  /* Reduce motion: sin scrub, contenido visible */
  @media (prefers-reduced-motion: reduce) {
    .iris-bg-video { transform: scale(1.12); }
    .iris-card__img, .iris-card__info { transform: none; }
    .iris-product-card__btn, .iris-card__cart { transition: none; }
  }
</style>
