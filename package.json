{
  "name": "logic2b-commerce-kit",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Logic2B Commerce Kit — plantilla de ecommerce ultraligera sobre Astro 5 + Cloudflare (demo: ecom.logic2b.com)",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "wrangler dev",
    "deploy": "astro build && wrangler deploy",
    "check": "astro check && vitest run && astro build",
    "test": "vitest run",
    "test:e2e": "node scripts/e2e.mjs",
    "db:migrate": "wrangler d1 migrations apply ecom-demo --local",
    "db:seed": "node seed/generate.ts > .wrangler/seed.sql && wrangler d1 execute ecom-demo --local --file .wrangler/seed.sql",
    "db:reset": "rm -rf .wrangler/state && pnpm db:migrate && pnpm db:seed"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^12.6.0",
    "@tailwindcss/vite": "^4.1.0",
    "astro": "^5.12.0",
    "stripe": "^18.0.0",
    "tailwindcss": "^4.1.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@cloudflare/workers-types": "^4.20250620.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0",
    "wrangler": "^4.20.0"
  }
}
